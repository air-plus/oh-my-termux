{
  "lang": "Go",
  "homepage": "https://github.com/git-lfs/git-lfs",
  "desc": {
    "cn": "Git LFS 是一个命令行扩展， 使用 Git 管理大文件的规范 。",
    "en": "Git LFS is a command line extension and specification for managing large files with Git."
  },
  "rule": {
    "darwin/brew": {
      "cmd": "brew install git-lfs",
      "reference": "https://github.com/git-lfs/git-lfs?tab=readme-ov-file#installing"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install git-lfs",
      "reference": "https://github.com/git-lfs/git-lfs/blob/main/INSTALLING.md"
    },
    "debian/apt": {
      "cmd": "sudo apt-get install git-lfs",
      "reference": "https://github.com/git-lfs/git-lfs/blob/main/INSTALLING.md"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install git-lfs",
      "reference": "https://github.com/git-lfs/git-lfs/blob/main/INSTALLING.md"
    },
    "fedora/yum": {
      "cmd": "sudo yum install git-lfs",
      "reference": "https://github.com/git-lfs/git-lfs/blob/main/INSTALLING.md"
    },
    "(win|wsl2)/choco": {
      "cmd": "choco install git-lfs.install",
      "reference": "https://community.chocolatey.org/packages/git-lfs.install#install"
    }
  }
}
