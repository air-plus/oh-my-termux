{
  "lang": "go",
  "homepage": "https://github.com/mr-karan/doggo",
  "desc": {
    "cn": "doggo 是一个用 Golang 编写的现代命令行 DNS 客户端",
    "en": "doggo is a modern command-line DNS client (like dig) written in Golang"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use doggo",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install doggo",
      "reference": "https://formulae.brew.sh/formula/doggo#default"
    },
    "arch/yay": {
      "cmd": "yay -S doggo-bin",
      "reference": "https://aur.archlinux.org/packages/doggo-bin"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop install doggo",
      "reference": "https://github.com/mr-karan/doggo#package-managers"
    }
  }
}
