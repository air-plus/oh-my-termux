{
  "lang": "C",
  "homepage": "https://github.com/ashang/unar",
  "desc": {
    "cn": "unar 是 The Unarchiver 的命令行解压引擎，支持 Zip、RAR、7z、Tar 等数十种归档格式，具备文件名编码自动检测功能。",
    "en": "unar is the command-line unarchiving engine of The Unarchiver, supporting dozens of archive formats with automatic filename encoding detection."
  },
  "rule": {
    "darwin/brew": {
      "cmd": "brew install unar",
      "reference": "https://github.com/ashang/unar#build-on-macos-via-brew"
    },
    "debian/apt": {
      "cmd": "sudo apt install unar",
      "reference": "https://command-not-found.com/unar",
      "dsnap": "unar"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt install unar",
      "reference": "https://command-not-found.com/unar",
      "dsnap": "unar"
    }
  },
  "binlist": [
    "unar"
  ]
}
