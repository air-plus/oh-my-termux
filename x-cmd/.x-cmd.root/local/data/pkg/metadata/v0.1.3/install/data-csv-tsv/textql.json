{
  "lang": "Go",
  "homepage": "https://github.com/dinedal/textql",
  "desc": {
    "cn": "对 CSV 或 TSV 等结构化文本执行 SQL",
    "en": "Execute SQL against structured text like CSV or TSV"
  },
  "rule": {
    "/brew": {
      "cmd": "brew install textql",
      "reference": "https://github.com/dinedal/textql?tab=readme-ov-file#install"
    },
    "arch/yay": {
      "cmd": "yay -S textql-git",
      "reference": "https://aur.archlinux.org/packages/textql-git"
    }
  }
}
