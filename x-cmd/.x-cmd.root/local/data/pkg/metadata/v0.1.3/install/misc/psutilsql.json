{
  "lang": "go",
  "homepage": "https://github.com/noborus/psutilsql",
  "desc": {
    "cn": "使用 gopsutil 库检索信息并使用 SQL 对其进行处理",
    "en": "Use the gopsutil library to retrieve information and process it with SQL"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use psutilsql",
      "reference": "https://x-cmd.com/install/"
    },
    "/go": {
      "cmd": "go get -u github.com/noborus/psutilsql...",
      "reference": "https://github.com/noborus/psutilsql?tab=readme-ov-file#install",
      "dsnap": "github.com/noborus/psutilsql"
    },
    "arch/yay": {
      "cmd": "yay -S psutilsql-bin",
      "reference": "https://aur.archlinux.org/packages/psutilsql-bin"
    }
  }
}
