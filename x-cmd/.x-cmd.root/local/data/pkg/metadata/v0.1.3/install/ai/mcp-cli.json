{
  "lang": "TypeScript",
  "homepage": "https://github.com/philschmid/mcp-cli",
  "desc": {
    "cn": "一个轻量级的、基于 Bun 的 CLI，用于与 MCP（模型上下文协议） 服务器交互",
    "en": "A lightweight, Bun-based CLI for interacting with MCP (Model Context Protocol) servers."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use mcp-cli",
      "reference": "https://x-cmd.com/install/"
    },
    "/curl": {
      "cmd": "curl -fsSL https://raw.githubusercontent.com/philschmid/mcp-cli/main/install.sh | bash",
      "reference": "https://github.com/philschmid/mcp-cli?tab=readme-ov-file#quick-start"
    },
    "/bun": {
      "cmd": "bun install -g https://github.com/philschmid/mcp-cli",
      "reference": "https://github.com/philschmid/mcp-cli?tab=readme-ov-file#quick-start"
    },
    "arch/yay": {
      "cmd": "yay -S mcp-cli-git",
      "reference": "https://aur.archlinux.org/packages/mcp-cli-git"
    }
  },
  "binlist": [
    "mcp-cli"
  ]
}
