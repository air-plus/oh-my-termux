{
  "lang": "Rust",
  "homepage": "https://github.com/yassinebridi/serpl",
  "desc": {
    "cn": "用于搜索和替换的简单终端 UI，类似于 VS Code 界面风格",
    "en": "A simple terminal UI for search and replace, ala VS Code."
  },
  "rule": {
    "/cargo": {
      "cmd": "cargo install serpl",
      "reference": "https://github.com/yassinebridi/serpl?tab=readme-ov-file#prerequisites",
      "dsnap": "serpl"
    },
    "darwin/brew": {
      "cmd": "brew install serpl",
      "reference": "https://github.com/yassinebridi/serpl?tab=readme-ov-file#os-specific-installation"
    },
    "arch/pacman": {
      "cmd": "pacman -S serpl",
      "reference": "https://github.com/yassinebridi/serpl?tab=readme-ov-file#os-specific-installation"
    },
    "nix/nixpkgs": {
      "cmd": "nix profile install nixpkgs#serpl",
      "reference": "https://github.com/yassinebridi/serpl?tab=readme-ov-file#nixnixos"
    }
  }
}
