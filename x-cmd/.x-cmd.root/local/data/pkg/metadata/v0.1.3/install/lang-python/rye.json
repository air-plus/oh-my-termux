{
  "lang": "rust",
  "desc": {
    "cn": "一个全面的 Python 项目和包管理解决方案",
    "en": "A comprehensive Python project and package management solution."
  },
  "homepage": "https://github.com/astral-sh/rye",
  "rule": {
    "/x": {
      "cmd": "x pkg use rye",
      "reference": "https://x-cmd.com/install/"
    },
    "(linux|darwin)/curl": {
      "cmd": "curl -sSf https://rye.astral.sh/get | bash",
      "reference": "https://rye.astral.sh/guide/installation/"
    },
    "arch/yay": {
      "cmd": "yay -S rye-git",
      "reference": "https://aur.archlinux.org/packages/rye-git"
    }
  }
}
