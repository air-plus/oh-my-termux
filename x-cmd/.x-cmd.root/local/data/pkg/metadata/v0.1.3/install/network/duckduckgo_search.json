{
  "lang": "python",
  "homepage": "https://github.com/deedy5/duckduckgo_search",
  "desc": {
    "en": "Search for words, documents, images, news, maps and text translation using the DuckDuckGo.com search engine. Downloading files and images to a local hard drive.",
    "cn": "使用 DuckDuckGo.com 搜索引擎搜索文字、文档、图像、视频、新闻、地图和文本翻译。将文件和图像下载到本地硬盘。"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use duckduckgo_search",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "pip install -U duckduckgo_search",
      "reference": "https://github.com/deedy5/duckduckgo_search?tab=readme-ov-file#install",
      "dsnap": "duckduckgo_search"
    },
    "arch/yay": {
      "cmd": "yay -S python-duckduckgo-search",
      "reference": "https://aur.archlinux.org/packages/python-duckduckgo-search"
    }
  }
}
