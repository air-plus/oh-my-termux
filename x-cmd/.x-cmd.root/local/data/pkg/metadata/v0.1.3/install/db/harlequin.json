{
  "lang": "python",
  "homepage": "https://harlequin.sh",
  "desc": {
    "cn": "Harlequin 是一个 SQL IDE，适用于 DuckDB、SQLite 和在终端中运行的其他数据库",
    "en": "Harlequin is a SQL IDE for DuckDB, SQLite, and other databases that runs in your Terminal"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use harlequin",
      "reference": "https://x-cmd.com/install/"
    },
    "/uv": {
      "cmd": "uv tool install harlequin",
      "reference": "https://github.com/tconbeer/harlequin?tab=readme-ov-file#installing-harlequin",
      "dsnap": "harlequin"
    },
    "/pip": {
      "cmd": "pip install harlequin",
      "reference": "https://github.com/tconbeer/harlequin?tab=readme-ov-file#installing-harlequin",
      "dsnap": "harlequin"
    },
    "darwin/brew": {
      "cmd": "brew install harlequin",
      "reference": "https://github.com/tconbeer/harlequin?tab=readme-ov-file#installing-harlequin"
    },
    "/pipx": {
      "cmd": "pipx install harlequin",
      "reference": "https://harlequin.sh/docs/getting-started"
    },
    "arch/yay": {
      "cmd": "yay -S harlequin",
      "reference": "https://aur.archlinux.org/packages/harlequin"
    }
  }
}
