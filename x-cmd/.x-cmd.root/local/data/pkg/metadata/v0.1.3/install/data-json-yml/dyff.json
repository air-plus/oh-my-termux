{
  "lang": "Go",
  "homepage": "https://github.com/homeport/dyff",
  "desc": {
    "cn": "用于 YAML 文件（有时也用于 JSON）的 diff 工具",
    "en": "A diff tool for YAML files, and sometimes JSON"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use dyff",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install homeport/tap/dyff",
      "reference": "https://github.com/homeport/dyff?tab=readme-ov-file#homebrew"
    },
    "/port": {
      "cmd": "sudo port install dyff",
      "reference": "https://github.com/homeport/dyff?tab=readme-ov-file#macports"
    },
    "/curl": {
      "cmd": "curl --silent --location https://git.io/JYfAY | bash",
      "reference": "https://github.com/homeport/dyff?tab=readme-ov-file#curl-to-shell-convenience-script"
    },
    "/go": {
      "cmd": "go install github.com/homeport/dyff/cmd/dyff@latest",
      "reference": "https://github.com/homeport/dyff?tab=readme-ov-file#build-from-source",
      "dsnap": "dyff"
    },
    "arch/yay": {
      "cmd": "yay -S dyff",
      "reference": "https://aur.archlinux.org/packages/dyff"
    }
  }
}
