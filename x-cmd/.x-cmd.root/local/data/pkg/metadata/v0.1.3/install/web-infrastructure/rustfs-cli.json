{
  "lang": "Rust",
  "homepage": "https://github.com/rustfs/cli",
  "desc": {
    "cn": "用 Rust 编写的与 S3 兼容的命令行客户端",
    "en": "A S3-compatible command-line client written in Rust"
  },
  "rule": {
    "(darwin|linux)/brew": {
      "cmd": "brew install rustfs/tap/rc",
      "reference": "https://github.com/rustfs/cli?tab=readme-ov-file#installation"
    },
    "(win|wsl2)/scoop": {
      "cmd": "scoop bucket add rustfs https://github.com/rustfs/scoop-bucket\nscoop install rustfs/rc\n",
      "reference": "https://github.com/rustfs/cli?tab=readme-ov-file#installation"
    },
    "/cargo": {
      "cmd": "cargo install rustfs-cli",
      "reference": "https://github.com/rustfs/cli?tab=readme-ov-file#installation"
    },
    "arch/yay": {
      "cmd": "yay -S rustfs-cli-bin",
      "reference": "https://aur.archlinux.org/packages/rustfs-cli-bin"
    }
  },
  "binlist": [
    "rc"
  ]
}
