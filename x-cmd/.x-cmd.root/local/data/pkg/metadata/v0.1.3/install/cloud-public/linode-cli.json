{
  "lang": "python",
  "homepage": "https://github.com/linode/linode-cli",
  "desc": {
    "cn": "Linode 命令行界面",
    "en": "The Linode Command Line Interface"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use linode-cli",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "pip3 install linode-cli",
      "reference": "https://github.com/linode/linode-cli?tab=readme-ov-file#install",
      "dsnap": "linode-cli"
    },
    "arch/yay": {
      "cmd": "yay -S linode-cli",
      "reference": "https://aur.archlinux.org/packages/linode-cli"
    },
    "darwin/brew": {
      "cmd": "brew install linode-cli",
      "reference": "https://github.com/linode/linode-cli/wiki/Installation#homebrew"
    }
  }
}
