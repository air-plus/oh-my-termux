{
  "lang": "Go",
  "homepage": "https://github.com/Broderick-Westrope/tetrigo",
  "desc": {
    "cn": "俄罗斯方块的 Golang 实现，遵循官方 2009 年俄罗斯方块设计指南 。",
    "en": "A Golang implementation of Tetris, following the official 2009 Tetris Design Guideline."
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S tetrigo-bin",
      "reference": "https://aur.archlinux.org/packages/tetrigo-bin"
    },
    "/go": {
      "cmd": "go install github.com/Broderick-Westrope/tetrigo/cmd/tetrigo@v0.1.6",
      "reference": "https://github.com/Broderick-Westrope/tetrigo?tab=readme-ov-file#build-from-source",
      "dsnap": "github.com/Broderick-Westrope/tetrigo/cmd/tetrigo@v0.1.6"
    }
  }
}
