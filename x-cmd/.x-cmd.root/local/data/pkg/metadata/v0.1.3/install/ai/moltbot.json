{
  "lang": "TypeScript",
  "homepage": "https://github.com/moltbot/moltbot",
  "desc": {
    "cn": "Moltbot 是一款在你个人设备上运行的私人 AI 助手。",
    "en": "Moltbot is a personal AI assistant you run on your own devices."
  },
  "rule": {
    "/curl": {
      "cmd": "curl -fsSL https://molt.bot/install.sh | bash",
      "reference": "https://www.molt.bot/"
    },
    "/npm": {
      "cmd": "npm install -g moltbot@latest",
      "reference": "https://www.molt.bot/"
    },
    "win/powershell": {
      "cmd": "x pwsh 'iwr -useb https://molt.bot/install.ps1 | iex'",
      "reference": "https://www.molt.bot/"
    }
  },
  "binlist": [
    "moltbot"
  ]
}
