{
  "lang": "Go",
  "homepage": "https://github.com/vicentereig/whatsapp-cli",
  "desc": {
    "cn": "一个基于 WhatsApp Web 多设备协议构建的独立 WhatsApp 命令行界面",
    "en": "A standalone command-line interface for WhatsApp built on the WhatsApp Web multidevice protocol."
  },
  "rule": {
    "/go": {
      "cmd": "go install github.com/vicentereig/whatsapp-cli@latest",
      "reference": "https://github.com/vicentereig/whatsapp-cli?tab=readme-ov-file#installation",
      "dsnap": "github.com/vicentereig/whatsapp-cli@latest"
    },
    "darwin/brew": {
      "cmd": "brew install vicentereig/tap/whatsapp-cli",
      "reference": "https://github.com/vicentereig/whatsapp-cli?tab=readme-ov-file#installation"
    }
  },
  "binlist": [
    "whatsapp-cli"
  ]
}
