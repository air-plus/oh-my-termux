{
  "lang": "Rust",
  "homepage": "https://github.com/chaosprint/asak",
  "desc": {
    "cn": "一个用 Rust 编写的带有 TUI 的跨平台音频录制/播放 CLI 工具",
    "en": "A cross-platform audio recording/playback CLI tool with TUI, written in Rust."
  },
  "rule": {
    "/cargo": {
      "cmd": "cargo install asak",
