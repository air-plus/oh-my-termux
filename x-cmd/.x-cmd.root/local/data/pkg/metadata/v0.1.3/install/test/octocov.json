{
  "lang": "Go",
  "homepage": "https://github.com/k1LoW/octocov",
  "desc": {
    "cn": "一个用于收集代码指标（代码覆盖率、代码与测试比率、测试执行时间和您自己的自定义指标）的工具包",
    "en": "a toolkit for collecting code metrics (code coverage, code to test ratio, test execution time and your own custom metrics)."
  },
  "rule": {
    "darwin/brew": {
      "cmd": "brew install k1LoW/tap/octocov",
      "reference": "https://github.com/k1LoW/octocov?tab=readme-ov-file#install"
    },
    "/go": {
      "cmd": "go install github.com/k1LoW/octocov@latest",
      "reference": "https://github.com/k1LoW/octocov?tab=readme-ov-file#install",
      "dsnap": "github.com/k1LoW/octocov@latest"
    }
  },
  "binlist": [
    "octocov"
  ]
}
