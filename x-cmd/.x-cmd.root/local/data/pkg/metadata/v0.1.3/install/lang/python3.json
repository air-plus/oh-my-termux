{
  "lang": "python",
  "homepage": "https://www.python.org/",
  "desc": {
    "cn": "Python 是一种结合了解释性、编译性、互动性和面向对象的脚本语言",
    "en": "Python is a Scripting language that combines interpretability, compilation, interactivity and object orientation"
  },
  "rule": {
    "/asdf": {
      "cmd": "x asdf use python",
      "reference": "https://github.com/danhper/asdf-python"
    },
    "darwin/brew": {
      "cmd": "brew install python3",
      "reference": "https://formulae.brew.sh/formula/python@3.13#default"
    },
    "debian/apt": {
      "cmd": "apt-get install python3",
      "reference": "https://command-not-found.com/python3",
      "dsnap": "python3"
    },
    "ubuntu/apt": {
      "cmd": "apt-get install python3",
      "reference": "https://command-not-found.com/python3",
      "dsnap": "python3"
    },
    "alpine/apk": {
      "cmd": "apk add python3",
      "reference": "https://command-not-found.com/python3",
      "dsnap": "python3"
    },
    "arch/pacman": {
      "cmd": "pacman -S python3",
      "reference": "https://command-not-found.com/python3"
    },
    "kali/apt": {
      "cmd": "apt-get install python3",
      "reference": "https://command-not-found.com/python3",
      "dsnap": "python3"
    },
    "fedora/dnf": {
      "cmd": "dnf install python3",
      "reference": "https://command-not-found.com/python3",
      "dsnap": "python3"
    },
    "raspbian/apt": {
      "cmd": "apt-get install python3",
      "reference": "https://command-not-found.com/python3"
    }
  },
  "binlist": [
    "python",
    "python3",
    "pip",
    "pip3"
  ]
}
