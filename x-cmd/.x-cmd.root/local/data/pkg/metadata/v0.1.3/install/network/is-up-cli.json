{
  "lang": "node",
  "homepage": "https://github.com/sindresorhus/is-up-cli#readme",
  "desc": {
    "en": "Check whether a website is up or down",
    "cn": "检查网站是否正常运行"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use is-up-cli",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install --global is-up-cli",
      "reference": "https://github.com/sindresorhus/is-up-cli?tab=readme-ov-file#install",
      "dsnap": "is-up-cli"
    },
    "arch/yay": {
      "cmd": "yay -S nodejs-is-up-cli",
      "reference": "https://aur.archlinux.org/packages/nodejs-is-up-cli"
    }
  }
}
