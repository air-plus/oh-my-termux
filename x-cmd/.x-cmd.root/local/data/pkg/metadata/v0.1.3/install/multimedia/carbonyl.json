{
  "lang": "Rust",
  "homepage": "https://github.com/fathyb/carbonyl",
  "desc": {
    "cn": "Carbonyl 是一款基于 Chromium 的浏览器，可在终端中运行",
    "en": "Carbonyl is a Chromium based browser built to run in a terminal"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use carbonyl",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install --global carbonyl",
      "reference": "https://github.com/fathyb/carbonyl?tab=readme-ov-file#npm",
      "dsnap": "carbonyl"
    },
    "arch/yay": {
      "cmd": "yay -S carbonyl",
      "reference": "https://aur.archlinux.org/packages/carbonyl"
    }
  }
}
