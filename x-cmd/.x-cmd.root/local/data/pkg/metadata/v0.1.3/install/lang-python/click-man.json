{
  "lang": "python",
  "homepage": "https://github.com/click-contrib/click-man",
  "desc": {
    "cn": "自动生成 python click 应用程序的手册页",
    "en": "Automate generation of man pages for python click applications"
  },
  "rule": {
    "/pip3": {
      "cmd": "pip3 install click-man",
      "reference": "https://github.com/click-contrib/click-man#installation"
    },
    "/pip": {
      "cmd": "pip install click-man",
      "reference": "https://github.com/click-contrib/click-man#installation",
      "dsnap": "click-man"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install python3-click-man",
      "reference": "https://command-not-found.com/click-man"
    },
    "arch/yay": {
      "cmd": "yay -S python-click-man",
      "reference": "https://aur.archlinux.org/packages/python-click-man"
    }
  }
}
