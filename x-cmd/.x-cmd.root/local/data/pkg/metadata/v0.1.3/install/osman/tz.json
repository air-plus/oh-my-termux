{
  "lang": "Go",
  "homepage": "https://github.com/oz/tz",
  "desc": {
    "cn": "时区助手",
    "en": "A time zone helper"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use tz",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S tz",
      "reference": "https://aur.archlinux.org/packages/tz"
    },
    "darwin/brew": {
      "cmd": "brew install tz",
      "reference": "https://github.com/oz/tz?tab=readme-ov-file#brew"
    },
    "/go": {
      "cmd": "go install github.com/oz/tz@latest",
      "reference": "https://github.com/oz/tz?tab=readme-ov-file#go",
      "dsnap": "github.com/oz/tz"
    }
  }
}
