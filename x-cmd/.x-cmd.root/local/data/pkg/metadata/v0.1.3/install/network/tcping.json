{
  "lang": "Go",
  "homepage": "https://github.com/pouriyajamshidi/tcping",
  "desc": {
    "cn": "一个通过 TCP 连接进行 ping 操作的工具",
    "en": "A tool to ping over a TCP connection"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use tcping",
      "reference": "https://x-cmd.com/install/"
    },
    "/go": {
      "cmd": "go install github.com/pouriyajamshidi/tcping@latest",
      "reference": "https://github.com/pouriyajamshidi/tcping?tab=readme-ov-file#download",
      "dsnap": "github.com/pouriyajamshidi/tcping@latest"
    },
    "arch/yay": {
      "cmd": "yay -S tcping-go",
      "reference": "https://aur.archlinux.org/packages/tcping-go"
    },
    "debian/apt": {
      "cmd": "wget https://github.com/pouriyajamshidi/tcping/releases/latest/download/tcping_amd64.deb -O /tmp/tcping.deb &&\nsudo apt install -y /tmp/tcping.deb\n",
      "reference": "https://github.com/pouriyajamshidi/tcping?tab=readme-ov-file#linux---debian-and-ubuntu",
      "dsnap": "tcping_amd64.deb"
    },
    "ubuntu/apt": {
      "cmd": "wget https://github.com/pouriyajamshidi/tcping/releases/latest/download/tcping_amd64.deb -O /tmp/tcping.deb &&\nsudo apt install -y /tmp/tcping.deb\n",
      "reference": "https://github.com/pouriyajamshidi/tcping?tab=readme-ov-file#linux---debian-and-ubuntu",
      "dsnap": "tcping_amd64.deb"
    },
    "darwin/brew": {
      "cmd": "brew install pouriyajamshidi/tap/tcping",
      "reference": "https://github.com/pouriyajamshidi/tcping?tab=readme-ov-file#download"
    }
  }
}
