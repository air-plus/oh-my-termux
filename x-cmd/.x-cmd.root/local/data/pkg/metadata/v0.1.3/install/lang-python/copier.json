{
  "lang": "Python",
  "homepage": "https://github.com/copier-org/copier",
  "desc": {
    "cn": "用于渲染项目模板的库和命令行实用程序",
    "en": "A library and CLI app for rendering project templates"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use copier",
      "reference": "https://x-cmd.com/install/"
    },
    "/pipx": {
      "cmd": "pipx install copier",
      "reference": "https://github.com/copier-org/copier?tab=readme-ov-file#installation"
    },
    "/pip": {
      "cmd": "pip install copier",
      "reference": "https://github.com/copier-org/copier?tab=readme-ov-file#installation",
      "dsnap": "copier"
    },
    "arch/yay": {
      "cmd": "yay -S python-copier",
      "reference": "https://aur.archlinux.org/packages/python-copier"
    }
  }
}
