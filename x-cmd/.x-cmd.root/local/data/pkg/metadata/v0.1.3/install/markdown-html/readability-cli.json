{
  "lang": "node",
  "homepage": "https://gitlab.com/gardenappl/readability-cli",
  "desc": {
    "cn": "Firefox Reader CLI，用于消除 HTML 页面不必要的内容，仅显示核心内容",
    "en": "Firefox Reader Mode in your terminal - get useful text from a web page using Mozilla's Readability library"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use readability-cli",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S nodejs-readability-cli",
      "reference": "https://aur.archlinux.org/packages/nodejs-readability-cli"
    },
    "/npm": {
      "cmd": "npm install -g readability-cli",
      "reference": "https://gitlab.com/gardenappl/readability-cli#nodejs",
      "dsnap": "readability-cli"
    }
  }
}
