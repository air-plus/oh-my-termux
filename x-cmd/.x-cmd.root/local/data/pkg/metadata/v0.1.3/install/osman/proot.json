{
  "lang": "Rust",
  "homepage": "https://github.com/proot-me/proot-rs",
  "desc": {
    "cn": "PRoot 的 Rust 实现，是基于 ptrace 的沙盒",
    "en": "Rust implementation of PRoot, a ptrace-based sandbox"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use proot",
      "reference": "https://x-cmd.com/install/"
    },
    "debian/apt": {
      "cmd": "sudo apt-get install proot",
      "reference": "https://command-not-found.com/proot"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install proot",
      "reference": "https://command-not-found.com/proot"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install proot",
      "reference": "https://command-not-found.com/proot",
      "dsnap": "proot"
    },
    "raspbian/apt": {
      "cmd": "sudo apt-get install proot",
      "reference": "https://command-not-found.com/proot"
    },
    "arch/yay": {
      "cmd": "yay -S proot",
      "reference": "https://aur.archlinux.org/packages/proot"
    }
  }
}
