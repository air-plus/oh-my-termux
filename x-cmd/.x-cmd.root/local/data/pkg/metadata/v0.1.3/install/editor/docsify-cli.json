{
  "lang": "JavaScript",
  "homepage": "https://github.com/docsifyjs/docsify-cli#readme",
  "desc": {
    "cn": "文档生成器，支持热加载",
    "en": "Document generator, supports hot loading"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use docsify-cli",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S docsify-cli",
      "reference": "https://aur.archlinux.org/packages/docsify-cli"
    },
    "/npm": {
      "cmd": "npm i docsify-cli -g",
      "reference": "https://github.com/docsifyjs/docsify-cli?tab=readme-ov-file#installation",
      "dsnap": "docsify-cli"
    }
  }
}
