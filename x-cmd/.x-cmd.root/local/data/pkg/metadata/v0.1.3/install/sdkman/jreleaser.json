{
  "lang": "Java",
  "homepage": "https://github.com/jreleaser/jreleaser/wiki/Release-early-access",
  "desc": {
    "cn": "JReleaser 是 Java 和非 Java 项目（Rust，Elixir，C#等）的发布自动化工具",
    "en": "JReleaser is a release automation tool for Java and non-Java projects (Rust, Elixir, C#, etc)"
  },
  "rule": {
    "/asdf": {
      "cmd": "x asdf use jreleaser",
      "reference": "https://github.com/joschi/asdf-jreleaser"
    },
    "/sdk": {
      "cmd": "sdk install jreleaser",
      "reference": "https://jreleaser.org/guide/latest/install.html#_stable"
    },
    "darwin/brew": {
      "cmd": "brew install jreleaser",
      "reference": "https://formulae.brew.sh/formula/jreleaser#default"
    },
    "darwin/port": {
      "cmd": "sudo port selfupdate && sudo port install jreleaser",
      "reference": "https://jreleaser.org/guide/latest/install.html"
    },
    "arch/yay": {
      "cmd": "yay -S jreleaser-bin",
      "reference": "https://aur.archlinux.org/packages/jreleaser-bin"
    }
  }
}
