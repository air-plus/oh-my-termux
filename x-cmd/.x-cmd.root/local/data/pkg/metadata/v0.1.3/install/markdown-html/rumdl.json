{
  "lang": "Rust",
  "homepage": "https://github.com/rvben/rumdl",
  "desc": {
    "cn": "rumdl 是 Rust 编写的 Markdown 检查和格式化工具，帮助你自动发现并修复文档问题。",
    "en": "rumdl is a Markdown linter and formatter written in Rust, helping you automatically detect and fix document issues. Install via x-cmd for cleaner documents."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use rumdl",
      "reference": "https://x-cmd.com/install/"
    },
    "/cargo": {
      "cmd": "cargo install rumdl",
      "reference": "https://github.com/rvben/rumdl?tab=readme-ov-file#installation",
      "dsnap": "rumdl"
    },
    "/npm": {
      "cmd": "npm install -g rumdl",
      "reference": "https://github.com/rvben/rumdl?tab=readme-ov-file#installation",
      "dsnap": "rumdl"
    },
    "/pip": {
      "cmd": "pip install rumdl",
      "reference": "https://github.com/rvben/rumdl?tab=readme-ov-file#installation"
    },
    "/uv": {
      "cmd": "uv tool install rumdl",
      "reference": "https://github.com/rvben/rumdl?tab=readme-ov-file#installation"
    },
    "/mise": {
      "cmd": "mise install rumdl",
      "reference": "https://github.com/rvben/rumdl?tab=readme-ov-file#installation"
    },
    "arch/pacman": {
      "cmd": "pacman -S rumdl",
      "reference": "https://github.com/rvben/rumdl?tab=readme-ov-file#installation"
    }
  },
  "binlist": [
    "rumdl"
  ]
}
