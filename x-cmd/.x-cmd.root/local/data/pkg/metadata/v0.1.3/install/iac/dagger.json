{
  "lang": "Go",
  "homepage": "https://docs.dagger.io/",
  "desc": {
    "cn": "Dagger 是一个集成平台，从头到尾协调应用程序到云的交付",
    "en": "Dagger is an integrated platform to orchestrate the delivery of applications to the cloud from start to finish"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use dagger",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use dagger",
      "reference": "https://github.com/virtualstaticvoid/asdf-dagger"
    },
    "darwin/brew": {
      "cmd": "brew install dagger/tap/dagger",
      "reference": "https://docs.dagger.io/quickstart/729236/cli"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop install dagger",
      "reference": "https://scoop.sh/#/apps?q=dagger"
    },
    "linux/curl": {
      "cmd": "curl -L https://dl.dagger.io/dagger/install.sh | sh",
      "reference": "https://docs.dagger.io/quickstart/729236/cli"
    },
    "win/powershell": {
      "cmd": "x pwsh Invoke-WebRequest -UseBasicParsing -Uri https://dl.dagger.io/dagger/install.ps1 | x pwsh Invoke-Expression",
      "reference": "https://docs.dagger.io/quickstart/729236/cli"
    },
    "arch/yay": {
      "cmd": "yay -S dagger-bin",
      "reference": "https://aur.archlinux.org/packages/dagger-bin"
    }
  }
}
