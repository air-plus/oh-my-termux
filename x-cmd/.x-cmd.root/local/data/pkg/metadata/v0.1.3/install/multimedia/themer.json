{
  "lang": "node",
  "homepage": "https://github.com/themerdev/themer#readme",
  "desc": {
    "en": "Customizable theme generator for editors, terminals, wallpaper, and more.",
    "cn": "可定制的编辑器、终端、壁纸等主题生成器。"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use themer",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install -g themer",
      "reference": "https://github.com/themerdev/themer?tab=readme-ov-file#installation",
      "dsnap": "themer"
    },
    "arch/yay": {
      "cmd": "yay -S themer",
      "reference": "https://aur.archlinux.org/packages/themer"
    }
  }
}
