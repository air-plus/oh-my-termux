{
  "lang": "c",
  "homepage": "https://github.com/nemuTUI/nemu",
  "desc": {
    "en": "Ncurses UI for QEMU",
    "cn": "QEMU 的 Ncurses UI"
  },
  "rule": {
    "alpine/apk": {
      "cmd": "apk add nemu",
      "reference": "https://github.com/nemuTUI/nemu?tab=readme-ov-file#packages",
      "dsnap": "nemu"
    },
    "freebsd/pkg": {
      "cmd": "pkg install nemu",
      "reference": "https://github.com/nemuTUI/nemu?tab=readme-ov-file#packages"
    },
    "darwin/brew": {
      "cmd": "brew install nemu",
      "reference": "https://github.com/nemuTUI/nemu?tab=readme-ov-file#packages"
    },
    "arch/yay": {
      "cmd": "yay -S nemu",
      "reference": "https://aur.archlinux.org/packages/nemu"
    }
  }
}
