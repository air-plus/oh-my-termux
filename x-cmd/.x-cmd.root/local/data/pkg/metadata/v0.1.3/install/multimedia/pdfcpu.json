{
  "lang": "Go",
  "homepage": "https://pdfcpu.io/",
  "desc": {
    "cn": "pdfcpu 是一个用 Go 编写的支持加密的 PDF 处理库",
    "en": "pdfcpu is a PDF processing library written in Go supporting encryption"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use pdfcpu",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install pdfcpu",
      "reference": "https://formulae.brew.sh/formula/pdfcpu#default"
    },
    "arch/yay": {
      "cmd": "yay -S pdfcpu",
      "reference": "https://aur.archlinux.org/packages/pdfcpu"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install golang-github-pdfcpu",
      "reference": "https://github.com/pdfcpu/pdfcpu#installation",
      "dsnap": "golang-github-pdfcpu"
    }
  }
}
