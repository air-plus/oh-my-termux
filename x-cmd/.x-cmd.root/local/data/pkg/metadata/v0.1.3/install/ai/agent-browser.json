{
  "lang": "Rust",
  "homepage": "https://github.com/vercel-labs/agent-browser",
  "desc": {
    "cn": "AI 代理的无头浏览器自动化 CLI。快速 Rust CLI，带 Node.js 后备。",
    "en": "Headless browser automation CLI for AI agents. Fast Rust CLI with Node.js fallback."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use agent-browser",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install -g agent-browser && agent-browser install",
      "reference": "https://github.com/vercel-labs/agent-browser#global-installation-recommended",
      "dsnap": "agent-browser"
    },
    "darwin/brew": {
      "cmd": "brew install agent-browser && agent-browser install",
      "reference": "https://github.com/vercel-labs/agent-browser#homebrew-macos"
    },
    "/cargo": {
      "cmd": "cargo install agent-browser && agent-browser install",
      "reference": "https://github.com/vercel-labs/agent-browser#cargo-rust"
    }
  },
  "binlist": [
    "agent-browser"
  ]
}
