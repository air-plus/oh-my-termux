{
  "lang": "Go",
  "homepage": "https://github.com/fullstorydev/grpcurl",
  "desc": {
    "cn": "grpcurl 是一个命令行工具，可让您与 gRPC 服务器交互",
    "en": "grpcurl is a command-line tool that lets you interact with gRPC servers"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use grpcurl",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use grpcurl",
      "reference": "https://github.com/asdf-community/asdf-grpcurl"
    },
    "darwin/brew": {
      "cmd": "brew install grpcurl",
      "reference": "https://github.com/fullstorydev/grpcurl?tab=readme-ov-file#homebrew-macos"
    },
    "arch/yay": {
      "cmd": "yay -S grpcurl-bin",
      "reference": "https://aur.archlinux.org/packages/grpcurl-bin"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install grpcurl",
      "reference": "https://repology.org/project/grpcurl/information"
    }
  }
}
