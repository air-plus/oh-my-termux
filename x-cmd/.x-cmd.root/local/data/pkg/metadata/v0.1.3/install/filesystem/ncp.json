{
  "lang": "javascript",
  "homepage": "https://github.com/AvianFlu/ncp",
  "desc": {
    "cn": "异步递归文件复制实用程序",
    "en": "Asynchronous recursive file copy utility."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use ncp",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S ncp",
      "reference": "https://aur.archlinux.org/packages/ncp"
    },
    "/npm": {
      "cmd": "npm i ncp",
      "reference": "https://www.npmjs.com/package/ncp",
      "dsnap": "ncp"
    }
  }
}
