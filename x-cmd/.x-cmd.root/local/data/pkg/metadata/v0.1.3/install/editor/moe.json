{
  "lang": "Nim",
  "homepage": "https://github.com/fox0430/moe",
  "desc": {
    "en": "A command line based editor inspired by Vim written in Nim",
    "cn": "一个受到 Vim 启发、用 Nim 语言编写的基于命令行的编辑器"
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S moe-nim",
      "reference": "https://aur.archlinux.org/packages/moe-nim"
    },
    "/nimble": {
      "cmd": "nimble install moe",
      "reference": "https://github.com/fox0430/moe?tab=readme-ov-file#install"
    }
  }
}
