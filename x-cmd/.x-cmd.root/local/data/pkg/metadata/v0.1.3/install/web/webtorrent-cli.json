{
  "lang": "javascript",
  "homepage": "https://webtorrent.io",
  "desc": {
    "cn": "webtorrent-cli 是一个简单的 torrent 客户端，可用于 Node.js，作为命令行应用",
    "en": "webtorrent-cli is a simple torrent client for use in node.js, as a command line app"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use webtorrent-cli",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install webtorrent-cli -g",
      "reference": "https://github.com/webtorrent/webtorrent-cli?tab=readme-ov-file#install",
      "dsnap": "webtorrent-cli"
    },
    "arch/yay": {
      "cmd": "yay -S webtorrent-cli",
      "reference": "https://aur.archlinux.org/packages/webtorrent-cli"
    }
  }
}
