{
  "lang": "c++",
  "homepage": "https://github.com/facebook/fbthrift",
  "desc": {
    "en": "Thrift is a serialization and RPC framework for service communication",
    "cn": "Thrift 是一种用于服务通信的序列化和 RPC 框架"
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S fbthrift-git",
      "reference": "https://aur.archlinux.org/packages/fbthrift-git"
    },
    "darwin/brew": {
      "cmd": "brew install fbthrift",
      "reference": "https://formulae.brew.sh/formula/fbthrift#default"
    }
  }
}
