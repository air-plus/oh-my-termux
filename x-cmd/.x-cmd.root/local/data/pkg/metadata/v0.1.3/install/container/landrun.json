{
  "lang": "Go",
  "homepage": "https://github.com/Zouuup/landrun",
  "desc": {
    "cn": "轻量级的安全沙盒，用于运行 Linux 进程。类似 Firejail，但具备内核级安全性，且开销极小。",
    "en": "A lightweight, secure sandbox for running Linux processes using Landlock. Think firejail, but with kernel-level security and minimal overhead."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use landrun",
      "reference": "https://x-cmd.com/install/"
    },
    "ubuntu/go": {
      "cmd": "go install github.com/zouuup/landrun/cmd/landrun@latest",
      "reference": "https://github.com/Zouuup/landrun?tab=readme-ov-file#installation",
      "dsnap": "github.com/zouuup/landrun/cmd/landrun@latest"
    },
    "fedora/go": {
      "cmd": "go install github.com/zouuup/landrun/cmd/landrun@latest",
      "reference": "https://github.com/Zouuup/landrun?tab=readme-ov-file#installation",
      "dsnap": "github.com/zouuup/landrun/cmd/landrun@latest"
    },
    "arch/go": {
      "cmd": "go install github.com/zouuup/landrun/cmd/landrun@latest",
      "reference": "https://github.com/Zouuup/landrun?tab=readme-ov-file#installation",
      "dsnap": "github.com/zouuup/landrun/cmd/landrun@latest"
    },
    "arch/yay": {
      "cmd": "yay -S landrun",
      "reference": "https://aur.archlinux.org/packages/landrun"
    },
    "alpine/go": {
      "cmd": "go install github.com/zouuup/landrun/cmd/landrun@latest",
      "reference": "https://github.com/Zouuup/landrun?tab=readme-ov-file#installation",
      "dsnap": "github.com/zouuup/landrun/cmd/landrun@latest"
    },
    "kali/go": {
      "cmd": "go install github.com/zouuup/landrun/cmd/landrun@latest",
      "reference": "https://github.com/Zouuup/landrun?tab=readme-ov-file#installation",
      "dsnap": "github.com/zouuup/landrun/cmd/landrun@latest"
    }
  }
}
