{
  "lang": "go",
  "desc": {
    "cn": "一个可移植的命令行 YAML、JSON、XML、CSV、TOML 的数据处理工具",
    "en": "yq is a portable command-line YAML, JSON, XML, CSV, TOML and properties processor"
  },
  "homepage": "https://github.com/mikefarah/yq",
  "rule": {
    "/x": {
      "cmd": "x pkg use yq",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use yq",
      "reference": "https://github.com/sudermanjr/asdf-yq"
    },
    "/go": {
      "cmd": "go install github.com/mikefarah/yq/v4@latest",
      "reference": "https://github.com/mikefarah/yq?tab=readme-ov-file#go-install",
      "dsnap": "github.com/mikefarah/yq/v4@latest"
    },
    "alpine/apk": {
      "cmd": "sudo apk add yq",
      "reference": "https://github.com/mikefarah/yq",
      "dsnap": "yq"
    },
    "darwin/brew": {
      "cmd": "brew install yq",
      "reference": "https://formulae.brew.sh/formula/yq#default"
    },
    "/snap": {
      "cmd": "snap install yq",
      "reference": "https://github.com/mikefarah/yq"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S go-yq",
      "reference": "https://github.com/mikefarah/yq"
    },
    "arch/yay": {
      "cmd": "yay -S yq",
      "reference": "https://aur.archlinux.org/packages/yq"
    },
    "(win|wsl2)/winget": {
      "cmd": "x winget install --id MikeFarah.yq",
      "reference": "https://github.com/mikefarah/yq"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop install main/yq",
      "reference": "https://github.com/mikefarah/yq"
    },
    "(win|wsl2)/choco": {
      "cmd": "x choco install yq",
      "reference": "https://github.com/mikefarah/yq"
    },
    "darwin/port": {
      "cmd": "sudo port selfupdate && sudo port install yq",
      "reference": "https://github.com/mikefarah/yq"
    }
  },
  "binlist": [
    "yq"
  ]
}
