{
  "lang": "Python",
  "homepage": "https://github.com/icloud-photos-downloader/icloud_photos_downloader",
  "desc": {
    "cn": "iCloud Photos Downloader 是一个从 iCloud 下载照片的命令行工具",
    "en": "iCloud Photos Downloader is a command-line tool to download photos from iCloud"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use icloudpd",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "pip install icloudpd",
      "reference": "https://github.com/icloud-photos-downloader/icloud_photos_downloader/blob/master/README_PYPI.md",
      "dsnap": "icloudpd"
    },
    "arch/yay": {
      "cmd": "yay -S icloudpd-bin",
      "reference": "https://aur.archlinux.org/packages/icloudpd-bin"
    }
  }
}
