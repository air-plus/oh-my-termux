{
  "lang": "Python",
  "homepage": "https://pyinfra.com/",
  "desc": {
    "cn": "一个多功能的 CLI 工具和 python 库，用于自动化基础设施",
    "en": "pyinfra automates infrastructure using Python. It’s fast and scales from one server to thousands"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use pyinfra",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "pip install pyinfra",
      "reference": "https://github.com/pyinfra-dev/pyinfra?tab=readme-ov-file#quickstart",
      "dsnap": "pyinfra"
    },
    "arch/yay": {
      "cmd": "yay -S pyinfra",
      "reference": "https://aur.archlinux.org/packages/pyinfra"
    }
  }
}
