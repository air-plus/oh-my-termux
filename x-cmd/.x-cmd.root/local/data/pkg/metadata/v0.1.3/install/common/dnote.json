{
  "lang": "go",
  "homepage": "https://www.getdnote.com/",
  "desc": {
    "cn": "Dnote 是一款面向程序员的简单命令行笔记本",
    "en": "Dnote is a simple command line notebook for programmers"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use dnote",
      "reference": "https://x-cmd.com/install/"
    },
    "/curl": {
      "cmd": "curl -s https://www.getdnote.com/install | sh",
      "reference": "https://github.com/dnote/dnote?tab=readme-ov-file#installation"
    },
    "arch/yay": {
      "cmd": "yay -S dnote-cli-bin",
      "reference": "https://aur.archlinux.org/packages/dnote-cli-bin"
    },
    "darwin/brew": {
      "cmd": "brew tap dnote/dnote \\\n&& brew install dnote\n",
      "reference": "https://github.com/dnote/dnote?tab=readme-ov-file#installation"
    }
  }
}
