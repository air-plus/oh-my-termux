{
  "lang": "go",
  "homepage": "https://github.com/go-gost/gost",
  "desc": {
    "cn": "GO 语言实现的安全隧道",
    "en": "A simple security tunnel written in Golang"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use gost",
      "reference": "https://x-cmd.com/install/"
    },
    "/go": {
      "cmd": "go install github.com/go-gost/gost/cmd/gost@master",
      "reference": "https://github.com/go-gost/gost",
      "dsnap": "github.com/go-gost/gost/cmd/gost@master"
    },
    "darwin/brew": {
      "cmd": "brew install gost",
      "reference": "https://formulae.brew.sh/formula/gost#default"
    },
    "debian/apt": {
      "cmd": "sudo apt-get install gost",
      "reference": "https://command-not-found.com/gost",
      "dsnap": "gost"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install gost",
      "reference": "https://command-not-found.com/gost",
      "dsnap": "gost"
    },
    "alpine/apk": {
      "cmd": "sudo apk add mosquitto",
      "reference": "https://command-not-found.com/mosquitto",
      "dsnap": "mosquitto"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S gost",
      "reference": "https://command-not-found.com/gost"
    },
    "arch/yay": {
      "cmd": "yay -S gost-v3-bin",
      "reference": "https://aur.archlinux.org/packages/gost-v3-bin"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install gost",
      "reference": "https://command-not-found.com/gost",
      "dsnap": "gost"
    },
    "raspbian/apt": {
      "cmd": "sudo apt-get install gost",
      "reference": "https://command-not-found.com/gost"
    }
  }
}
