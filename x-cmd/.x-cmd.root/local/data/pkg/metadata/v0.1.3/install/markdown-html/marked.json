{
  "lang": "node",
  "homepage": "https://marked.js.org",
  "desc": {
    "cn": "markdown 处理器和编译器",
    "en": "A markdown parser and compiler"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use marked",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S nodejs-marked",
      "reference": "https://aur.archlinux.org/packages/nodejs-marked"
    },
    "/npm": {
      "cmd": "npm install -g marked",
      "reference": "https://github.com/markedjs/marked?tab=readme-ov-file#installation",
      "dsnap": "marked"
    }
  }
}
