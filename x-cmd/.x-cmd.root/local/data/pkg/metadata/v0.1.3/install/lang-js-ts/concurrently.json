{
  "lang": "node",
  "homepage": "https://github.com/open-cli-tools/concurrently#readme",
  "desc": {
    "en": "Run npm commands concurrently",
    "cn": "并行运行 npm 命令"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use concurrently",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm i -g concurrently",
      "reference": "https://github.com/open-cli-tools/concurrently?tab=readme-ov-file#installation",
      "dsnap": "concurrently"
    },
    "arch/yay": {
      "cmd": "yay -S concurrently",
      "reference": "https://aur.archlinux.org/packages/concurrently"
    }
  }
}
