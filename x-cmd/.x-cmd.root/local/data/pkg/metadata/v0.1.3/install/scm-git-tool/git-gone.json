{
  "lang": "rust",
  "homepage": "https://crates.io/crates/git-gone",
  "desc": {
    "cn": "清理提取请求的陈旧 Git 分支",
    "en": "Cleanup stale Git branches of pull requests"
  },
  "rule": {
    "/cargo": {
      "cmd": "cargo install git-gone",
      "reference": "https://crates.io/crates/git-gone",
      "dsnap": "git-gone"
    },
    "arch/yay": {
      "cmd": "yay -S git-gone",
      "reference": "https://aur.archlinux.org/packages/git-gone"
    }
  }
}
