{
  "lang": "Python",
  "homepage": "https://doitlive.readthedocs.io/",
  "desc": {
    "cn": "doitlive 是终端中实时演示的工具",
    "en": "doitlive is a tool for live presentations in the terminal"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use doitlive",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install doitlive",
      "reference": "https://github.com/sloria/doitlive?tab=readme-ov-file#macos-with-homebrew"
    },
    "arch/yay": {
      "cmd": "yay -S doitlive",
      "reference": "https://aur.archlinux.org/packages/doitlive"
    },
    "/pip": {
      "cmd": "pip install doitlive",
      "reference": "https://github.com/sloria/doitlive?tab=readme-ov-file#with-pip",
      "dsnap": "doitlive"
    }
  }
}
