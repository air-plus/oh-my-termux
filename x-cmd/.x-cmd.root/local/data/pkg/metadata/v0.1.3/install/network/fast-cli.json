{
  "homepage": "https://github.com/sindresorhus/fast-cli#readme",
  "desc": {
    "cn": "使用 fast.com 测试下载和上传速度",
    "en": "Test your download and upload speed using fast.com"
  },
  "lang": "node",
  "rule": {
    "/x": {
      "cmd": "x pkg use fast-cli",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install --global fast-cli",
      "reference": "https://github.com/sindresorhus/fast-cli?tab=readme-ov-file#install",
      "dsnap": "fast-cli"
    },
    "arch/yay": {
      "cmd": "yay -S nodejs-fast-cli",
      "reference": "https://aur.archlinux.org/packages/nodejs-fast-cli"
    }
  }
}
