{
  "lang": "Go",
  "homepage": "https://gitea.com/gitea/act_runner",
  "desc": {
    "en": "Gitea Actions runner",
    "cn": "运行 Gitea Actions"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use act_runner",
      "reference": "https://x-cmd.com/install/"
    },
    "/build": {
      "cmd": "git clone https://gitea.com/gitea/act_runner.git &&\n  cd act_runner &&\n  make build\n",
      "reference": "https://gitea.com/gitea/act_runner#installation"
    },
    "arch/yay": {
      "cmd": "yay -S act-runner-bin",
      "reference": "https://aur.archlinux.org/packages/act-runner-bin"
    }
  }
}
