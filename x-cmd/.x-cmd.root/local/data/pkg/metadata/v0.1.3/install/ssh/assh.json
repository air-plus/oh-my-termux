{
  "lang": "go",
  "homepage": "https://github.com/moul/assh",
  "desc": {
    "cn": "assh 是一个智能工具，旨在紧密包裹您的 SSH 和增强它，就像一个超级英雄服装，有各种小工具安装",
    "en": "assh is a smart tool that was designed to wrap tightly around your SSH and enhance it, like a superhero suit that has various gadgets installed"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use assh",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use assh",
      "reference": "https://github.com/zekker6/asdf-assh"
    },
    "/go": {
      "cmd": "go install moul.io/assh/v2@latest",
      "reference": "https://github.com/moul/assh?tab=readme-ov-file#install",
      "dsnap": "moul.io/assh/v2"
    },
    "darwin/brew": {
      "cmd": "brew install assh",
      "reference": "https://github.com/moul/assh?tab=readme-ov-file#install"
    },
    "arch/yay": {
      "cmd": "yay -S assh-bin",
      "reference": "https://aur.archlinux.org/packages/assh-bin"
    }
  }
}
