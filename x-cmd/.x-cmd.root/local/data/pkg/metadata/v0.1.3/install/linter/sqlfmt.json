{
  "lang": "Python",
  "homepage": "https://sqlfmt.com/",
  "desc": {
    "cn": "SQL 的格式化工具",
    "en": "SQL formatting tool"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use sqlfmt",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S python-shandy-sqlfmt",
      "reference": "https://aur.archlinux.org/packages/python-shandy-sqlfmt"
    },
    "/pipx": {
      "cmd": "pipx install shandy-sqlfmt",
      "reference": "https://github.com/tconbeer/sqlfmt?tab=readme-ov-file#install-using-pipx-recommended"
    }
  }
}
