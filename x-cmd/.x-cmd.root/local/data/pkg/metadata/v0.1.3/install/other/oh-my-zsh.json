{
  "lang": "shell",
  "homepage": "https://ohmyz.sh/",
  "desc": {
    "cn": "Oh My Zsh 是一个开源、社区驱动的框架，用于管理您的 zsh 配置",
    "en": "Oh My Zsh is an open source, community-driven framework for managing your zsh configuration"
  },
  "rule": {
    "/curl": {
      "cmd": "sh -c \"$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)\"",
      "reference": "https://ohmyz.sh/"
    },
    "/wget": {
      "cmd": "sh -c \"$(wget https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh -O -)\"",
      "reference": "https://ohmyz.sh/"
    },
    "/fetch": {
      "cmd": "sh -c \"$(fetch -o - https://install.ohmyz.sh/)\"",
      "reference": "https://ohmyz.sh/"
    },
    "arch/yay": {
      "cmd": "yay -S oh-my-zsh-git",
      "reference": "https://aur.archlinux.org/packages/oh-my-zsh-git"
    }
  }
}
