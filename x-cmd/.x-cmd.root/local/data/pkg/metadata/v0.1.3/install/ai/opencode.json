{
  "lang": "TypeScript",
  "homepage": "https://github.com/anomalyco/opencode",
  "desc": {
    "cn": "为终端构建的人工智能编码代理",
    "en": "The AI coding agent built for the terminal."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use opencode",
      "reference": "https://x-cmd.com/install/"
    },
    "/curl": {
      "cmd": "curl -fsSL https://opencode.ai/install | bash",
      "reference": "https://github.com/anomalyco/opencode?tab=readme-ov-file#installation"
    },
    "/npm": {
      "cmd": "npm i -g opencode-ai@latest",
      "reference": "https://github.com/anomalyco/opencode?tab=readme-ov-file#installation"
    },
    "(win|wsl2)/scoop": {
      "cmd": "scoop bucket add extras; scoop install extras/opencode",
      "reference": "https://github.com/anomalyco/opencode?tab=readme-ov-file#installation"
    },
    "darwin/brew": {
      "cmd": "brew install opencode",
      "reference": "https://github.com/anomalyco/opencode?tab=readme-ov-file#installation"
    },
    "arch/paru": {
      "cmd": "paru -S opencode-bin",
      "reference": "https://github.com/anomalyco/opencode?tab=readme-ov-file#installation"
    },
    "/mise": {
      "cmd": "mise use --pin -g ubi:sst/opencode",
      "reference": "https://github.com/anomalyco/opencode?tab=readme-ov-file#installation"
    },
    "nixos/nix": {
      "cmd": "nix run nixpkgs#opencode",
      "reference": "https://github.com/anomalyco/opencode?tab=readme-ov-file#installation"
    }
  },
  "binlist": [
    "opencode"
  ]
}
