{
  "lang": "python",
  "homepage": "https://pygments.org/",
  "desc": {
    "cn": "Pygments 是用 Python 编写的通用语法高亮工具",
    "en": "Pygments is a generic syntax highlighter written in Python"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use pygments",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "pip install Pygments",
      "reference": "https://github.com/pygments/pygments?tab=readme-ov-file#installing",
      "dsnap": "Pygments"
    }
  }
}
