{
  "lang": "typescript",
  "homepage": "https://github.com/sindresorhus/emoj",
  "desc": {
    "cn": "从命令行文本中查找相关表情符号",
    "en": "Find relevant emoji from text on the command-line"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use emoj",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install --global emoj",
      "reference": "https://github.com/sindresorhus/emoj?tab=readme-ov-file#install",
      "dsnap": "emoj"
    },
    "arch/yay": {
      "cmd": "yay -S emoj",
      "reference": "https://aur.archlinux.org/packages/emoj"
    }
  }
}
