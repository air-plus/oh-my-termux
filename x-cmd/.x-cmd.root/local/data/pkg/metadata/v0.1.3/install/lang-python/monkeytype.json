{
  "lang": "Python",
  "homepage": "https://github.com/Instagram/MonkeyType",
  "desc": {
    "cn": "一个 Python 库，通过收集运行时类型生成静态类型注释",
    "en": "A Python library that generates static type annotations by collecting runtime types"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use monkeytype",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "pip install MonkeyType",
      "reference": "https://github.com/Instagram/MonkeyType?tab=readme-ov-file#installing",
      "dsnap": "MonkeyType"
    },
    "arch/yay": {
      "cmd": "yay -S python-monkeytype",
      "reference": "https://aur.archlinux.org/packages/python-monkeytype"
    }
  }
}
