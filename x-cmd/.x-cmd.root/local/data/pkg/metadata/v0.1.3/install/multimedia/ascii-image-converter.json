{
  "lang": "go",
  "homepage": "https://github.com/TheZoraiz/ascii-image-converter",
  "desc": {
    "cn": "用于将图像转换为 ascii art 并在控制台上打印",
    "en": "A cross-platform command-line tool to convert images into ascii art and print them on the console"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use ascii-image-converter",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install TheZoraiz/ascii-image-converter/ascii-image-converter",
      "reference": "https://github.com/TheZoraiz/ascii-image-converter?tab=readme-ov-file#homebrew"
    },
    "/go": {
      "cmd": "go install github.com/TheZoraiz/ascii-image-converter@latest",
      "reference": "https://github.com/TheZoraiz/ascii-image-converter?tab=readme-ov-file#go",
      "dsnap": "github.com/TheZoraiz/ascii-image-converter@latest"
    },
    "/snap": {
      "cmd": "sudo snap install ascii-image-converter",
      "reference": "https://github.com/TheZoraiz/ascii-image-converter?tab=readme-ov-file#snap"
    },
    "arch/yay": {
      "cmd": "yay -S ascii-image-converter",
      "reference": "https://aur.archlinux.org/packages/ascii-image-converter"
    },
    "debian/apt": {
      "cmd": "sudo apt install -y ascii-image-converter",
      "reference": "https://github.com/TheZoraiz/ascii-image-converter?tab=readme-ov-file#debian-or-ubuntu-based-distros",
      "dsnap": "ascii-image-converter"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt install -y ascii-image-converter",
      "reference": "https://github.com/TheZoraiz/ascii-image-converter?tab=readme-ov-file#debian-or-ubuntu-based-distros",
      "dsnap": "ascii-image-converter"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop install ascii-image-converter",
      "reference": "https://github.com/TheZoraiz/ascii-image-converter?tab=readme-ov-file#scoop"
    }
  }
}
