{
  "lang": "Rust",
  "homepage": "https://github.com/amber-lang/Amber",
  "desc": {
    "cn": "可编译为 Bash 的编程语言",
    "en": "Programming language that compiles to Bash"
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S amber-bash-bin",
      "reference": "https://aur.archlinux.org/packages/amber-bash-bin"
    },
    "/curl": {
      "cmd": "bash -- <(curl -sL \"https://github.com/amber-lang/amber/releases/download/0.4.0-alpha/install.sh\") --user",
      "reference": "https://docs.amber-lang.com/getting_started/installation"
    },
    "darwin/brew": {
      "cmd": "brew install amber-lang/amber/amber-lang",
      "reference": "https://docs.amber-lang.com/getting_started/installation"
    }
  }
}
