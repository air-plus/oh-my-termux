{
  "lang": "Zig",
  "homepage": "https://github.com/lightpanda-io/browser",
  "desc": {
    "cn": "专为人工智能和自动化设计的无头浏览器",
    "en": "the headless browser designed for AI and automation"
  },
  "rule": {
    "/curl": {
      "cmd": "curl -fsSL https://pkg.lightpanda.io/install.sh | bash",
      "reference": "https://lightpanda.io/docs/open-source/installation"
    },
    "/docker": {
      "cmd": "docker run -d --name lightpanda -p 9222:9222 lightpanda/browser:nightly",
      "reference": "https://lightpanda.io/docs/open-source/installation#install-from-docker"
    },
    "arch/yay": {
      "cmd": "yay -S lightpanda-bin",
      "reference": "https://aur.archlinux.org/packages/lightpanda-bin"
    }
  },
  "binlist": [
    "lightpanda"
  ]
}
