{
  "lang": "go",
  "homepage": "https://github.com/mvdan/gofumpt",
  "desc": {
    "cn": "更为严格的 gofumpt",
    "en": "A stricter gofmt"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use gofumpt",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S gofumpt-git",
      "reference": "https://aur.archlinux.org/packages/gofumpt-git"
    },
    "/asdf": {
      "cmd": "x asdf use gofumpt",
      "reference": "https://github.com/looztra/asdf-gofumpt"
    },
    "/go": {
      "cmd": "go install mvdan.cc/gofumpt@latest",
      "reference": "https://github.com/mvdan/gofumpt?tab=readme-ov-file#gofumpt",
      "dsnap": "mvdan.cc/gofumpt@latest"
    }
  }
}
