{
  "lang": "C",
  "homepage": "https://davidgriffith.gitlab.io/frotz/",
  "desc": {
    "cn": "Infocom 游戏和其他 Z-machine 游戏的解释器",
    "en": "An interpreter for Infocom games and other Z-machine games."
  },
  "rule": {
    "darwin/brew": {
      "cmd": "brew install frotz",
      "reference": "https://formulae.brew.sh/formula/frotz#default"
    },
    "alpine/apk": {
      "cmd": "apk add frotz",
      "reference": "https://pkgs.alpinelinux.org/package/edge/community/x86_64/frotz",
      "dsnap": "frotz"
    },
    "ubuntu/apt": {
      "cmd": "apt install frotz",
      "reference": "https://packages.ubuntu.com/oracular/frotz",
      "dsnap": "frotz"
    },
    "fedora/dnf": {
      "cmd": "dnf install frotz",
      "reference": "https://packages.fedoraproject.org/pkgs/frotz/frotz/",
      "dsnap": "frotz"
    },
    "arch/pacman": {
      "cmd": "pacman -S frotz",
      "reference": "https://archlinux.org/packages/extra/x86_64/frotz/"
    }
  },
  "binlist": [
    "frotz"
  ]
}
