{
  "lang": "Rust",
  "homepage": "https://dotenv-linter.github.io/#/",
  "desc": {
    "cn": "dotenv-linter 可以检查/修复/比较 .env 文件是否存在可能导致应用程序故障的问题",
    "en": "dotenv-linter can check / fix / compare .env files for problems that may cause the application to malfunction"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use dotenv-linter",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S dotenv-linter-bin",
      "reference": "https://aur.archlinux.org/packages/dotenv-linter-bin"
    },
    "/curl": {
      "cmd": "curl -sSfL https://git.io/JLbXn | sh -s",
      "reference": "https://github.com/dotenv-linter/dotenv-linter?tab=readme-ov-file#pre-compiled-binary"
    },
    "/wget": {
      "cmd": "wget -q -O - https://git.io/JLbXn | sh -s",
      "reference": "https://github.com/dotenv-linter/dotenv-linter?tab=readme-ov-file#pre-compiled-binary"
    }
  }
}
