{
  "lang": "CSS",
  "homepage": "https://github.com/ryanoasis/nerd-fonts",
  "desc": {
    "cn": "GeistMono 字体",
    "en": "GeistMono font"
  },
  "rule": {
    "(linux|darwin|wsl2)/": {
      "cmd": "x font nerd install GeistMono",
      "reference": "https://x-cmd.com/mod/font"
    },
    "win/powershell": {
      "cmd": "x pwsh Invoke-WebRequest -Uri https://github.com/ryanoasis/nerd-fonts/releases/download/v3.1.1/GeistMono.zip -OutFile GeistMono.zip",
      "reference": "https://github.com/ryanoasis/nerd-fonts/releases/"
    },
    "/curl": {
      "cmd": "curl -OL https://github.com/ryanoasis/nerd-fonts/releases/download/v3.1.1/GeistMono.tar.xz",
      "reference": "https://github.com/ryanoasis/nerd-fonts/releases/"
    },
    "/wget": {
      "cmd": "wget https://github.com/ryanoasis/nerd-fonts/releases/download/v3.1.1/GeistMono.tar.xz",
      "reference": "https://github.com/ryanoasis/nerd-fonts/releases/"
    }
  }
}
