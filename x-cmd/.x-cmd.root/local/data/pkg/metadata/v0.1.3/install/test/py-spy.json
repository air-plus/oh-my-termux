{
  "lang": "Rust",
  "desc": {
    "cn": "Py-Spy 是 Python 程序的抽样探测器",
    "en": "py-spy is a sampling profiler for Python programs"
  },
  "homepage": "https://github.com/benfred/py-spy",
  "rule": {
    "/x": {
      "cmd": "x pkg use py-spy",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "pip install py-spy",
      "reference": "https://github.com/benfred/py-spy?tab=readme-ov-file#installation",
      "dsnap": "py-spy"
    },
    "arch/yay": {
      "cmd": "yay -S py-spy",
      "reference": "https://aur.archlinux.org/packages/py-spy"
    }
  }
}
