{
  "lang": "Python",
  "homepage": "https://github.com/scottrogowski/code2flow",
  "desc": {
    "cn": "将 Python 和 JavaScript 代码转换为 DOT 流程图",
    "en": "Code2flow generates call graphs for dynamic programming language"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use code2flow",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip3": {
      "cmd": "pip3 install code2flow",
      "reference": "https://github.com/scottrogowski/code2flow?tab=readme-ov-file#installation"
    },
    "arch/yay": {
      "cmd": "yay -S python-code2flow",
      "reference": "https://aur.archlinux.org/packages/python-code2flow"
    }
  }
}
