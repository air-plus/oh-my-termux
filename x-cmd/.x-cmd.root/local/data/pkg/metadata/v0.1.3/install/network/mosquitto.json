{
  "lang": "c",
  "homepage": "https://mosquitto.org/",
  "desc": {
    "cn": "实现 MQTT 协议的消息代理",
    "en": "Message broker implementing the MQTT protocol"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use mosquitto",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install mosquitto",
      "reference": "https://mosquitto.org/download/"
    },
    "debian/apt": {
      "cmd": "sudo apt-get install mosquitto",
      "reference": "https://command-not-found.com/mosquitto",
      "dsnap": "mosquitto"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install mosquitto",
      "reference": "https://command-not-found.com/mosquitto",
      "dsnap": "mosquitto"
    },
    "alpine/apk": {
      "cmd": "sudo apk add mosquitto",
      "reference": "https://command-not-found.com/mosquitto",
      "dsnap": "mosquitto"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S mosquitto",
      "reference": "https://command-not-found.com/mosquitto"
    },
    "arch/yay": {
      "cmd": "yay -S mosquitto-git",
      "reference": "https://aur.archlinux.org/packages/mosquitto-git"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install mosquitto",
      "reference": "https://command-not-found.com/mosquitto",
      "dsnap": "mosquitto"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install mosquitto",
      "reference": "https://command-not-found.com/mosquitto",
      "dsnap": "mosquitto"
    },
    "raspbian/apt": {
      "cmd": "sudo apt-get install mosquitto",
      "reference": "https://command-not-found.com/mosquitto"
    }
  }
}
