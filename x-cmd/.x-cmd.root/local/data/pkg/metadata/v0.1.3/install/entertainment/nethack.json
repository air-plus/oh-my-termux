{
  "lang": "C",
  "homepage": "https://www.nethack.org/",
  "desc": {
    "cn": "一款经典的开源 roguelike 地牢探险游戏，以其深度、复杂性和极高的重玩价值闻名",
    "en": "A classic open-source roguelike dungeon exploration game, renowned for its depth, complexity, and immense replayability."
  },
  "rule": {
    "darwin/brew": {
      "cmd": "brew install nethack",
      "reference": "https://formulae.brew.sh/formula/nethack#default"
    },
    "alpine/apk": {
      "cmd": "apk add nethack",
      "reference": "https://pkgs.alpinelinux.org/package/edge/community/x86_64/nethack",
      "dsnap": "nethack"
    },
    "ubuntu/apt": {
      "cmd": "apt install nethack-console",
      "reference": "https://packages.ubuntu.com/oracular/nethack",
      "dsnap": "nethack-console"
    },
    "fedora/dnf": {
      "cmd": "dnf install nethack",
      "reference": "https://packages.fedoraproject.org/pkgs/nethack/nethack/",
      "dsnap": "nethack"
    },
    "arch/pacman": {
      "cmd": "pacman -S nethack",
      "reference": "https://archlinux.org/packages/extra/x86_64/nethack/"
    },
    "(win|wsl2)/scoop": {
      "cmd": "scoop bucket add games && scoop install games/nethack",
      "reference": "https://scoop.sh/#/apps?q=nethack"
    }
  },
  "binlist": [
    "nethack"
  ]
}
