{
  "lang": "TypeScript",
  "homepage": "https://github.com/Fission-AI/OpenSpec",
  "desc": {
    "cn": "面向规范驱动开发（spec-driven development）的 AI 原生系统",
    "en": "AI-native system for spec-driven development"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use openspec",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install -g @fission-ai/openspec",
      "reference": "https://github.com/Fission-AI/OpenSpec?tab=readme-ov-file#step-1-install-the-cli-globally",
      "dsnap": "@fission-ai/openspec"
    },
    "arch/yay": {
      "cmd": "yay -S openspec",
      "reference": "https://aur.archlinux.org/packages/openspec"
    }
  },
  "binlist": [
    "openspec"
  ]
}
