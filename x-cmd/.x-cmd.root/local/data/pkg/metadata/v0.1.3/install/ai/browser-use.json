{
  "lang": "Python",
  "homepage": "https://github.com/browser-use/browser-use",
  "desc": {
    "cn": "让 AI 代理可以访问网站。轻松实现在线任务自动化",
    "en": "Make websites accessible for AI agents. Automate tasks online with ease."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use browser-use",
      "reference": "https://x-cmd.com/install/"
    },
    "/curl": {
      "cmd": "curl -fsSL https://browser-use.com/cli/install.sh | bash",
      "reference": "https://docs.browser-use.com/open-source/browser-use-cli"
    },
    "/uv": {
      "cmd": "uv tool install browser-use",
      "reference": "https://pypi.org/project/browser-use/"
    },
    "arch/yay": {
      "cmd": "yay -S browser-use-cli",
      "reference": "https://aur.archlinux.org/packages/browser-use-cli"
    }
  },
  "binlist": [
    "browser-use",
    "browseruse",
    "browser",
    "browser-use-tui",
    "bu"
  ]
}
