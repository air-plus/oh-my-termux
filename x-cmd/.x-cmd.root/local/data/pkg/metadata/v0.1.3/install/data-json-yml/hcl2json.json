{
  "lang": "Go",
  "homepage": "https://github.com/tmccombs/hcl2json",
  "desc": {
    "cn": "将 hcl2 转换为 json",
    "en": "Convert hcl2 to json"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use hcl2json",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install hcl2json",
      "reference": "https://github.com/tmccombs/hcl2json?tab=readme-ov-file#mac-os"
    },
    "darwin/port": {
      "cmd": "sudo port install hcl2json",
      "reference": "https://github.com/tmccombs/hcl2json?tab=readme-ov-file#mac-os"
    }
  }
}
