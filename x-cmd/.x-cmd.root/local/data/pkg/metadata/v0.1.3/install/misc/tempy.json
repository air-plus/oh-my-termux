{
  "lang": "Python",
  "homepage": "https://github.com/noprobelm/tempy",
  "desc": {
    "en": "A simple, visually pleasing weather report in your terminal",
    "cn": "在终端中显示一个简洁且美观的天气预报"
  },
  "rule": {
    "/pip": {
      "cmd": "pip install git+https://github.com/noprobelm/tempy",
      "reference": "https://github.com/noprobelm/tempy?tab=readme-ov-file#installation",
      "dsnap": "https://github.com/noprobelm/tempy/archive/refs/heads/main.zip"
    },
    "arch/yay": {
      "cmd": "yay -S tempy",
      "reference": "https://aur.archlinux.org/packages/tempy"
    }
  }
}
