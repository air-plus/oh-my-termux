{
  "lang": "rust",
  "homepage": "https://github.com/Wilfred/difftastic",
  "desc": {
    "cn": "Difftastic 是一种结构差异工具，可根据语法对文件进行比较。",
    "en": "Difftastic is a structural diff tool that compares files based on their syntax."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use difft",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S difftastic-git",
      "reference": "https://aur.archlinux.org/packages/difftastic-git"
    },
    "darwin/brew": {
      "cmd": "brew install difftastic",
      "reference": "https://formulae.brew.sh/formula/difftastic#default"
    }
  }
}
