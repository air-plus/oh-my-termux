{
  "lang": "Python",
  "homepage": "https://github.com/pirxthepilot/wtfis",
  "desc": {
    "cn": "适用于非机器人的被动主机名、域名和 IP 查找工具",
    "en": "Passive hostname, domain and IP lookup tool for non-robots"
  },
  "rule": {
    "/pip": {
      "cmd": "pip install wtfis",
      "reference": "https://github.com/pirxthepilot/wtfis?tab=readme-ov-file#install",
      "dsnap": "wtfis"
    },
    "arch/yay": {
      "cmd": "yay -S wtfis",
      "reference": "https://aur.archlinux.org/packages/wtfis"
    },
    "darwin/brew": {
      "cmd": "brew install wtfis",
      "reference": "https://github.com/pirxthepilot/wtfis?tab=readme-ov-file#install"
    }
  },
  "binlist": [
    "wtfis"
  ]
}
