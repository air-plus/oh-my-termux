{
  "lang": "Ballerina",
  "homepage": "https://ballerina.io/",
  "desc": {
    "cn": "网络分布式应用程序的编程语言",
    "en": "Programming Language for Network Distributed Applications"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use ballerina",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install ballerina",
      "reference": "https://formulae.brew.sh/formula/ballerina#default"
    },
    "arch/yay": {
      "cmd": "yay -S ballerina-bin",
      "reference": "https://aur.archlinux.org/packages/ballerina-bin"
    }
  }
}
