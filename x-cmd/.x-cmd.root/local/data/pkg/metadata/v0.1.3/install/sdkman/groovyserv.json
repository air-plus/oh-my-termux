{
  "lang": "Groovy",
  "homepage": "https://kobo.github.io/groovyserv/index.html#",
  "desc": {
    "cn": "Groovy 的启动加速器。",
    "en": "Groovy's startup acceralator."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use groovyserv",
      "reference": "https://x-cmd.com/install/"
    },
    "/sdk": {
      "cmd": "sdk install groovyserv",
      "reference": "http://kobo.github.io/groovyserv/howtoinstall.html#sdk"
    },
    "darwin/brew": {
      "cmd": "brew install groovyserv",
      "reference": "http://kobo.github.io/groovyserv/howtoinstall.html#homebrew"
    },
    "arch/yay": {
      "cmd": "yay -S groovyserv-bin",
      "reference": "https://aur.archlinux.org/packages/groovyserv-bin"
    }
  }
}
