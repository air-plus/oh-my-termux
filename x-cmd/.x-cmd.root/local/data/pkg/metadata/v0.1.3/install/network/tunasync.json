{
  "lang": "go",
  "homepage": "https://github.com/tuna/tunasync",
  "desc": {
    "cn": "镜像 job 管理工具",
    "en": "Mirror job management tool"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use tunasync",
