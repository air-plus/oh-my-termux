{
  "lang": "Groovy",
  "homepage": "http://kobo.github.io/gaiden/",
  "desc": {
    "cn": "Gaiden 是一种工具，可以轻松使用 Markdown 创建文档",
    "en": "Gaiden is a tool that makes it easy to create documentation with Markdown"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use gaiden",
      "reference": "https://x-cmd.com/install/"
    },
    "/sdk": {
      "cmd": "sdk install gaiden",
      "reference": "http://kobo.github.io/gaiden/getting-started.html#installation"
    }
  }
}
