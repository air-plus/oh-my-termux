{
  "lang": "Go",
  "homepage": "https://github.com/charmbracelet/crush",
  "desc": {
    "cn": "由 Charm 团队提供的终端的 AI 编码代理",
    "en": "AI encoding agent for terminals provided by the Charm team"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use crush",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install charmbracelet/tap/crush",
      "reference": "https://github.com/charmbracelet/crush?tab=readme-ov-file#installation"
    },
    "/npm": {
      "cmd": "npm install -g @charmland/crush",
      "reference": "https://github.com/charmbracelet/crush?tab=readme-ov-file#installation",
      "dsnap": "@charmland/crush"
    },
    "arch/yay": {
      "cmd": "yay -S crush-bin",
      "reference": "https://github.com/charmbracelet/crush?tab=readme-ov-file#installation"
    },
    "nix/nix": {
      "cmd": "nix run github:numtide/nix-ai-tools#crush",
      "reference": "https://github.com/charmbracelet/crush?tab=readme-ov-file#installation"
    },
    "/go": {
      "cmd": "go install github.com/charmbracelet/crush@latest",
      "reference": "https://github.com/charmbracelet/crush?tab=readme-ov-file#installation",
      "dsnap": "github.com/charmbracelet/crush@latest"
    }
  },
  "binlist": [
    "crush"
  ]
}
