{
  "lang": "go",
  "homepage": "https://github.com/qiniu/qshell",
  "desc": {
    "cn": "使用七牛云 API 服务的命令行工具",
    "en": "Shell Tools for Qiniu Cloud"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use qshell",
      "reference": "https://x-cmd.com/install/"
    },
    "/curl/amd64": {
      "cmd": "curl -sSL https://github.com/qiniu/qshell/releases/download/latest/qshell-v2.18.0-darwin-amd64.tar.gz | tar xzvf - -C ~/.local/bin",
      "reference": "https://github.com/qiniu/qshell/releases"
    },
    "arch/yay": {
      "cmd": "yay -S qiniu-qshell-bin",
      "reference": "https://aur.archlinux.org/packages/qiniu-qshell-bin"
    }
  }
}
