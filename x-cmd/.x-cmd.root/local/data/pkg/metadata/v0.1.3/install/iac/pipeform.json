{
  "lang": "Go",
  "homepage": "https://github.com/magodo/pipeform",
  "desc": {
    "cn": "pipeform 是 Terraform 运行时 TUI。",
    "en": "A TUI for Terraform runtime progress."
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S pipeform",
      "reference": "https://aur.archlinux.org/packages/pipeform"
    },
    "/go": {
      "cmd": "go install github.com/magodo/pipeform@main",
      "reference": "https://github.com/magodo/pipeform#installation",
      "dsnap": "github.com/magodo/pipeform@main"
    }
  }
}
