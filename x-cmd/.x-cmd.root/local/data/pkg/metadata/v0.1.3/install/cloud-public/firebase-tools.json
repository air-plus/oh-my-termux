{
  "lang": "node",
  "homepage": "https://github.com/firebase/firebase-tools",
  "desc": {
    "cn": "Firebase 命令行界面 (CLI) 工具可用于从命令行测试、管理和部署 Firebase 项目",
    "en": "The Firebase Command Line Interface (CLI) Tools can be used to test, manage, and deploy your Firebase project from the command line"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use firebase-tools",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install -g firebase-tools",
      "reference": "https://github.com/firebase/firebase-tools?tab=readme-ov-file#node-package",
      "dsnap": "firebase-tools"
    },
    "arch/yay": {
      "cmd": "yay -S firebase-tools",
      "reference": "https://aur.archlinux.org/packages/firebase-tools"
    },
    "/curl": {
      "cmd": "curl -sL firebase.tools | bash",
      "reference": "https://github.com/firebase/firebase-tools?tab=readme-ov-file#standalone-binary"
    }
  }
}
