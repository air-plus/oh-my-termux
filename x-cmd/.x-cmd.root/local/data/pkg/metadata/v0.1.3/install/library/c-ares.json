{
  "lang": "c",
  "homepage": "https://c-ares.org/",
  "desc": {
    "cn": "c-ares 是一个用于异步 DNS 请求(包括名称解析)的 C 库",
    "en": "c-ares is a C library for asynchronous DNS requests (including name resolves)"
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S c-ares-git",
      "reference": "https://aur.archlinux.org/packages/c-ares-git"
    },
    "darwin/brew": {
      "cmd": "brew install c-ares",
      "reference": "https://formulae.brew.sh/formula/c-ares#default"
    }
  }
}
