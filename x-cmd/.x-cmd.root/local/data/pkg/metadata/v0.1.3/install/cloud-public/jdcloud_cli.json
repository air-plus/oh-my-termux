{
  "lang": "python",
  "homepage": "https://github.com/jdcloud-api/jdcloud-cli",
  "desc": {
    "cn": "京东云 CLI",
    "en": "jdcloud CLI"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use jdcloud_cli",
      "reference": "https://x-cmd.com/install/"
    },
    "linux/pip": {
      "cmd": "pip install -U jdcloud_cli",
      "reference": "https://github.com/jdcloud-api/jdcloud-cli#linux--mac"
    },
    "darwin/pip": {
      "cmd": "pip install -U jdcloud_cli",
      "reference": "https://github.com/jdcloud-api/jdcloud-cli#linux--mac"
    },
    "(win|wsl2)/curl": {
      "cmd": "curl https://raw.githubusercontent.com/jdcloud-api/jdcloud-cli/master/jdcloud_cli/resources/jdc.rc > ~/jdc.rc \\\n&& echo 'source ~/jdc.rc' >> ~/.bashrc \\\n&& echo 'export PYTHONIOENCODING=\"UTF-8\"' >> ~/.bashrc \\\n&& source ~/.bashrc\n",
      "reference": "https://github.com/jdcloud-api/jdcloud-cli#windows"
    }
  }
}
