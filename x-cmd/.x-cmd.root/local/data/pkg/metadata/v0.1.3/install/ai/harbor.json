{
  "lang": "Python",
  "homepage": "https://github.com/laude-institute/harbor",
  "desc": {
    "cn": "用于运行代理评估以及创建和使用 RL 环境的框架（依赖 git 和 Docker）",
    "en": "a framework for running agent evaluations and creating and using RL environments (requires git and Docker)"
  },
  "rule": {
    "/uv": {
      "cmd": "uv tool install harbor",
      "reference": "https://github.com/laude-institute/harbor?tab=readme-ov-file#installation"
    },
    "/pip": {
      "cmd": "pip install harbor",
      "reference": "https://github.com/laude-institute/harbor?tab=readme-ov-file#installation"
    }
  },
  "binlist": [
    "harbor"
  ]
}
