{
  "lang": "Rust",
  "homepage": "https://github.com/medialab/xan",
  "desc": {
    "cn": "用于直接从 shell 处理 CSV 文件的命令行工具",
    "en": "a command line tool that can be used to process CSV files directly from the shell."
  },
  "rule": {
    "/cargo": {
      "cmd": "cargo install xan --locked",
      "reference": "https://github.com/medialab/xan?tab=readme-ov-file#how-to-install",
      "dsnap": "xan"
    },
    "darwin/brew": {
      "cmd": "brew install xan",
      "reference": "https://github.com/medialab/xan?tab=readme-ov-file#how-to-install"
    },
    "(win|wsl2)/scoop": {
      "cmd": "scoop bucket add extras\nscoop install xan\n",
      "reference": "https://github.com/medialab/xan?tab=readme-ov-file#how-to-install"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S xan",
      "reference": "https://github.com/medialab/xan?tab=readme-ov-file#how-to-install"
    },
    "nix/nix-shell": {
      "cmd": "nix-shell -p xan",
      "reference": "https://github.com/medialab/xan?tab=readme-ov-file#how-to-install"
    }
  },
  "binlist": [
    "xan"
  ]
}
