    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install howdoi",
      "reference": "https://command-not-found.com/howdoi",
      "dsnap": "howdoi"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install howdoi",
      "reference": "https://command-not-found.com/howdoi",
      "dsnap": "howdoi"
    },
    "raspbian/apt": {
      "cmd": "sudo apt-get install howdoi",
      "reference": "https://command-not-found.com/howdoi"
    },
    "mint/apt": {
      "cmd": "sudo apt-get install howdoi",
      "reference": "https://command-not-found.com/howdoi"
    },
    "opensuse/zypper": {
