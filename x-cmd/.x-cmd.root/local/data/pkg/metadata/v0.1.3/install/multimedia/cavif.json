{
  "lang": "Rust",
  "homepage": "https://lib.rs/crates/cavif",
  "desc": {
    "cn": "AVIF 图像的编码器/转换器",
    "en": "Encoder/converter for AVIF images"
  },
  "rule": {
    "/cargo": {
      "cmd": "cargo install cavif",
      "reference": "https://lib.rs/crates/cavif",
      "dsnap": "cavif"
    },
    "arch/yay": {
      "cmd": "yay -S cavif",
      "reference": "https://aur.archlinux.org/packages/cavif"
    }
  }
}
