{
  "lang": "rust",
  "homepage": "https://github.com/newdee/git-commit-helper",
  "desc": {
    "cn": "使用人工智能自动生成并提交 Git 消息",
    "en": "Auto generate && commit git messages with AI"
  },
  "rule": {
    "/cargo": {
      "cmd": "cargo install git-commit-helper",
      "reference": "https://github.com/newdee/git-commit-helper?tab=readme-ov-file#install",
      "dsnap": "git-commit-helper"
    },
    "arch/yay": {
      "cmd": "yay -S git-commit-helper",
      "reference": "https://aur.archlinux.org/packages/git-commit-helper"
    }
  }
}
