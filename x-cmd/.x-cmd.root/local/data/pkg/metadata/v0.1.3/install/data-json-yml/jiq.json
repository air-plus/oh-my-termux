{
  "lang": "Go",
  "homepage": "https://github.com/fiatjaf/jiq",
  "desc": {
    "cn": "使用 jq 表达式的交互式 JSON 查询工具",
    "en": "interactive JSON query tool using jq expressions"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use jiq",
      "reference": "https://x-cmd.com/install/"
    },
    "/go": {
      "cmd": "go install github.com/fiatjaf/jiq/cmd/jiq@latest",
      "reference": "https://github.com/fiatjaf/jiq?tab=readme-ov-file#installation",
      "dsnap": "github.com/fiatjaf/jiq/cmd/jiq@latest"
    },
    "arch/yay": {
      "cmd": "yay -S jiq-bin",
      "reference": "https://aur.archlinux.org/packages/jiq-bin"
    }
  }
}
