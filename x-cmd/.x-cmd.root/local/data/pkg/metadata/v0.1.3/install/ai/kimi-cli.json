{
  "lang": "Python",
  "homepage": "https://github.com/MoonshotAI/kimi-cli",
  "desc": {
    "cn": "MoonshotAI 推出的 AI Agent，可帮助您完成软件开发任务和终端操作",
    "en": "An AI agent released by MoonshotAI that helps you with software development tasks and terminal operations."
  },
  "rule": {
    "/x": {
      "cmd": "x kimi --install",
      "reference": "https://www.x-cmd.com/mod/kimi"
    },
    "/curl": {
      "cmd": "curl -LsSf https://code.kimi.com/install.sh | bash",
      "reference": "https://moonshotai.github.io/kimi-cli/en/guides/getting-started.html#installation"
    },
    "/uv": {
      "cmd": "uv tool install --python 3.13 kimi-cli",
      "reference": "https://moonshotai.github.io/kimi-cli/en/guides/getting-started.html#installation"
    },
    "win/powershell": {
      "cmd": "x pwsh 'Invoke-RestMethod https://code.kimi.com/install.ps1 | Invoke-Expression'",
      "reference": "https://moonshotai.github.io/kimi-cli/en/guides/getting-started.html#installation"
    },
    "arch/yay": {
      "cmd": "yay -S kimi-cli",
      "reference": "https://aur.archlinux.org/packages/kimi-cli"
    }
  },
  "binlist": [
    "kimi"
  ]
}
