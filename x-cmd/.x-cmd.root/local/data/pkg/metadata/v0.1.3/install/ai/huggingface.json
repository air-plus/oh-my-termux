{
  "lang": "Python",
  "homepage": "https://huggingface.co/",
  "desc": {
    "cn": "Huggingface Hub 的官方 Python 客户端",
    "en": "The official Python client for the Huggingface Hub"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use huggingface",
      "reference": "https://x-cmd.com/install/"
    },
    "/curl": {
      "cmd": "curl -LsSf https://hf.co/cli/install.sh | bash",
      "reference": "https://huggingface.co/docs/huggingface_hub/installation"
    },
    "/pip": {
      "cmd": "pip install huggingface_hub",
      "reference": "https://huggingface.co/docs/huggingface_hub/installation",
      "dsnap": "huggingface_hub"
    },
    "/conda": {
      "cmd": "conda install -c conda-forge huggingface_hub",
      "reference": "https://huggingface.co/docs/huggingface_hub/installation"
    },
    "darwin/brew": {
      "cmd": "brew install huggingface-cli",
      "reference": "https://huggingface.co/docs/huggingface_hub/installation"
    },
    "(win|wsl2)/powershell": {
      "cmd": "x pwsh -ExecutionPolicy ByPass -c \"irm https://hf.co/cli/install.ps1 | iex\"",
      "reference": "https://huggingface.co/docs/huggingface_hub/installation"
    }
  }
}
