{
  "lang": "Rust",
  "homepage": "https://github.com/RustScan/RustScan",
  "desc": {
    "cn": "现代端口扫描器",
    "en": "The Modern Port Scanner"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use rustscan",
