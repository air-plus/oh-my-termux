{
  "lang": "go",
  "homepage": "https://github.com/caddyserver/caddy",
  "desc": {
    "cn": "多功能多平台的 HTTP/1-2-3 Web 服务器",
    "en": "Fast, multi-platform web server with automatic HTTPS"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use caddy",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use caddy",
      "reference": "https://github.com/salasrod/asdf-caddy"
    },
    "/build": {
      "cmd": "git clone \"https://github.com/caddyserver/caddy.git\" \\\n&& cd caddy/cmd/caddy/ \\\n&& go build\n",
      "reference": "https://github.com/caddyserver/caddy?tab=readme-ov-file#for-development"
    },
    "arch/yay": {
      "cmd": "yay -S caddy-git",
      "reference": "https://aur.archlinux.org/packages/caddy-git"
    }
  }
}
