{
  "lang": "Rust",
  "homepage": "https://github.com/pkolaczk/fclones",
  "desc": {
    "cn": "高效的重复文件查找器和删除器",
    "en": "Efficient duplicate file finder and remover"
  },
  "rule": {
    "linux/snap": {
      "cmd": "snap install fclones",
      "reference": "https://github.com/pkolaczk/fclones?tab=readme-ov-file#installation"
    },
    "darwin/brew": {
      "cmd": "brew install fclones",
      "reference": "https://github.com/pkolaczk/fclones?tab=readme-ov-file#installation"
    },
    "/cargo": {
      "cmd": "cargo install fclones",
      "reference": "https://github.com/pkolaczk/fclones?tab=readme-ov-file#installation",
      "dsnap": "fclones"
    },
    "arch/yay": {
      "cmd": "yay -S fclones-git",
      "reference": "https://aur.archlinux.org/packages/fclones-git"
    }
  },
  "binlist": [
    "fclones"
  ]
}
