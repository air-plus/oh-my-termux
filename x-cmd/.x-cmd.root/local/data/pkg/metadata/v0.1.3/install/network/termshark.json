{
  "lang": "go",
  "homepage": "https://termshark.io",
  "desc": {
    "cn": "一个受到 Wireshark 启发的 tshark 终端用户界面",
    "en": "A terminal UI for tshark, inspired by Wireshark"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use termshark",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install termshark",
      "reference": "https://formulae.brew.sh/formula/termshark#default"
    },
    "darwin/port": {
      "cmd": "sudo port selfupdate && sudo port install termshark",
      "reference": "https://github.com/gcla/termshark/blob/master/docs/Packages.md#macports"
    },
    "debian/apt": {
      "cmd": "sudo apt install termshark",
      "reference": "https://github.com/gcla/termshark/blob/master/docs/Packages.md#debian",
      "dsnap": "termshark"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt install termshark",
      "reference": "https://github.com/gcla/termshark/blob/master/docs/Packages.md#ubuntu",
      "dsnap": "termshark"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S termshark",
      "reference": "https://linux-packages.com/arch-linux/package/termshark"
    },
    "arch/yay": {
      "cmd": "yay -S termshark-git",
      "reference": "https://aur.archlinux.org/packages/termshark-git"
    },
    "nix/nixpkgs": {
      "cmd": "sudo nix-channel --add https://nixos.org/channels/nixpkgs-unstable \\\n&& sudo nix-channel --update \\\n&& sudo nix-env -iA nixpkgs.termshark\n",
      "reference": "https://github.com/gcla/termshark/blob/master/docs/Packages.md#nixos"
    },
    "freebsd/pkg": {
      "cmd": "pkg install termshark",
      "reference": "https://github.com/gcla/termshark/blob/master/docs/Packages.md#freebsd"
    },
    "kali/apt": {
      "cmd": "sudo apt install termshark",
      "reference": "https://github.com/gcla/termshark/blob/master/docs/Packages.md#kali-linux",
      "dsnap": "termshark"
    },
    "/snap": {
      "cmd": "sudo snap install termshark",
      "reference": "https://github.com/gcla/termshark/blob/master/docs/Packages.md#snapcraft"
    }
  }
}
