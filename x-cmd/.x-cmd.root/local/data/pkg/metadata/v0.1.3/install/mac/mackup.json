{
  "lang": "python",
  "homepage": "https://github.com/lra/mackup",
  "desc": {
    "cn": "用于保持应用程序设置同步 (OS X/Linux)",
    "en": "Keep your application settings in sync (OS X/Linux)"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use mackup",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S mackup",
      "reference": "https://aur.archlinux.org/packages/mackup"
    },
    "/pip": {
      "cmd": "pip install --upgrade mackup",
      "reference": "https://github.com/lra/mackup#quickstart",
      "dsnap": "mackup"
    },
    "darwin/brew": {
      "cmd": "brew install mackup",
      "reference": "https://github.com/lra/mackup#quickstart"
    }
  }
}
