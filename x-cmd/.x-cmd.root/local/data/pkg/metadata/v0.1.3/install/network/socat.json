{
  "lang": "shell",
  "homepage": "http://www.dest-unreach.org/socat/",
  "desc": {
    "cn": "一个多功能的网络工具",
    "en": "A versatile web tool"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use socat",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install socat",
      "reference": "https://formulae.brew.sh/formula/socat#default"
    },
    "debian/apt": {
      "cmd": "sudo apt-get install socat",
      "reference": "https://command-not-found.com/socat",
      "dsnap": "socat"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install socat",
      "reference": "https://command-not-found.com/socat",
      "dsnap": "socat"
    },
    "alpine/apk": {
      "cmd": "sudo apk add socat",
      "reference": "https://command-not-found.com/socat",
      "dsnap": "socat"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S socat",
      "reference": "https://command-not-found.com/socat"
    },
    "arch/yay": {
      "cmd": "yay -S socat-git",
      "reference": "https://aur.archlinux.org/packages/socat-git"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install socat",
      "reference": "https://command-not-found.com/socat",
      "dsnap": "socat"
    },
    "centos/yum": {
      "cmd": "sudo yum install socat",
      "reference": "https://command-not-found.com/socat"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install socat",
      "reference": "https://command-not-found.com/socat",
      "dsnap": "socat"
    },
    "raspbian/apt": {
      "cmd": "sudo apt-get install socat",
      "reference": "https://command-not-found.com/socat"
    }
  }
}
