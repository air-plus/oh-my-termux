{
  "lang": "Go",
  "homepage": "https://github.com/cloudflare/cloudflare-go",
  "desc": {
    "cn": "用于与 Cloudflare 帐户交互的 CLI 应用程序",
    "en": "A CLI application for interacting with a Cloudflare account"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use flarectl",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use flarectl",
      "reference": "https://github.com/ORCID/asdf-flarectl"
    },
    "arch/yay": {
      "cmd": "yay -S flarectl-bin",
      "reference": "https://aur.archlinux.org/packages/flarectl-bin"
    },
    "/go": {
      "cmd": "go get github.com/cloudflare/cloudflare-go",
      "reference": "https://github.com/cloudflare/cloudflare-go?tab=readme-ov-file#installation",
      "dsnap": "github.com/cloudflare/cloudflare-go"
    }
  }
}
