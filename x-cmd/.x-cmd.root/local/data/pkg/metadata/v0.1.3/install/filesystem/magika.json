{
  "lang": "Python",
  "homepage": "https://google.github.io/magika/",
  "desc": {
    "cn": "Magika 是使用深度学习检测常见文件内容类型的工具",
    "en": "Magika is a tool to detect common file content types, using deep learning"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use magika",
      "reference": "https://x-cmd.com/install/"
    },
    "arch/yay": {
      "cmd": "yay -S magika",
      "reference": "https://aur.archlinux.org/packages/magika"
    },
    "/pip": {
      "cmd": "pip install magika",
      "reference": "https://github.com/google/magika/?tab=readme-ov-file#installation",
      "dsnap": "magika"
    }
  }
}
