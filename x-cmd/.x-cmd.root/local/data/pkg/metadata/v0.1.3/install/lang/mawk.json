{
  "lang": "c",
  "homepage": "https://invisible-island.net/mawk/",
  "desc": {
    "en": "mawk is an interpreter for the AWK Programming Language.",
    "cn": "Mawk 是 AWK 编程语言的解释器。"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use mawk",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install mawk",
      "reference": "https://formulae.brew.sh/formula/mawk"
    },
    "debian/apt": {
      "cmd": "sudo apt-get install mawk",
      "reference": "https://command-not-found.com/mawk",
      "dsnap": "mawk"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install mawk",
      "reference": "https://command-not-found.com/mawk",
      "dsnap": "mawk"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install mawk",
      "reference": "https://command-not-found.com/mawk",
      "dsnap": "mawk"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install mawk",
      "reference": "https://command-not-found.com/mawk",
      "dsnap": "mawk"
    },
    "arch/yay": {
      "cmd": "yay -S mawk",
      "reference": "https://aur.archlinux.org/packages/mawk"
    },
    "raspbian/apt": {
      "cmd": "sudo apt-get install mawk",
      "reference": "https://command-not-found.com/mawk"
    }
  }
}
