{
  "lang": "Python",
  "homepage": "https://github.com/lxgr-linux/pokete",
  "desc": {
    "cn": "类似口袋妖怪的游戏",
    "en": "A terminal based Pokemon like game"
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S pokete",
      "reference": "https://aur.archlinux.org/packages/pokete"
    },
    "/pip": {
      "cmd": "pip install pokete",
      "reference": "https://github.com/lxgr-linux/pokete?tab=readme-ov-file#installation",
      "dsnap": "pokete"
    }
  },
  "binlist": [
    "pokete"
  ]
}
