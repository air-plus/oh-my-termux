{
  "lang": "Kotlin",
  "homepage": "https://github.com/varabyte/kobweb/",
  "desc": {
    "cn": "Kobweb 是一个基于 Kotlin 的框架，用于创建网站和 Web 应用程序",
    "en": "Kobweb is a Kotlin-based framework for creating websites and web applications"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use kobweb",
      "reference": "https://x-cmd.com/install/"
    },
    "/sdk": {
      "cmd": "sdk install kobweb",
      "reference": "https://github.com/varabyte/kobweb#sdkman"
    },
    "darwin/brew": {
      "cmd": "brew install varabyte/tap/kobweb",
      "reference": "https://github.com/varabyte/kobweb#homebrew"
    },
    "arch/trizen": {
      "cmd": "sudo trizen -S kobweb",
      "reference": "https://github.com/varabyte/kobweb#arch-linux"
    },
    "arch/yay": {
      "cmd": "yay -S kobweb",
      "reference": "https://aur.archlinux.org/packages/kobweb"
    }
  }
}
