{
  "lang": "Python",
  "homepage": "https://github.com/Aider-AI/aider",
  "desc": {
    "cn": "aider 是一个终端中的 AI 配对编程工具。",
    "en": "aider is AI pair programming in your terminal"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use aider",
      "reference": "https://x-cmd.com/install/"
    },
    "win/powershell": {
      "cmd": "x pwsh -ExecutionPolicy ByPass -c \"irm https://aider.chat/install.ps1 | iex\"",
      "reference": "https://aider.chat/docs/install.html#windows"
    },
    "/curl": {
      "cmd": "curl -LsSf https://aider.chat/install.sh | sh",
      "reference": "https://aider.chat/docs/install.html#mac--linux"
    },
    "/wget": {
      "cmd": "wget -qO- https://aider.chat/install.sh | sh",
      "reference": "https://aider.chat/docs/install.html#mac--linux"
    },
    "/pipx": {
      "cmd": "pipx install aider-chat",
      "reference": "https://aider.chat/docs/install.html#install-with-pipx"
    },
    "/pip": {
      "cmd": "python -m pip install -U --upgrade-strategy only-if-needed aider-chat",
      "reference": "https://aider.chat/docs/install.html#install-with-pip",
      "dsnap": "aider-chat"
    },
    "/uv": {
      "cmd": "uv tool install --force --python python3.12 aider-chat@latest",
      "reference": "https://aider.chat/docs/install.html#install-with-uv",
      "dsnap": "aider-chat"
    },
    "darwin/brew": {
      "cmd": "brew install aider",
      "reference": "https://formulae.brew.sh/formula/aider#default"
    },
    "arch/yay": {
      "cmd": "yay -S aider-chat",
      "reference": "https://aur.archlinux.org/packages/aider-chat"
    }
  }
}
