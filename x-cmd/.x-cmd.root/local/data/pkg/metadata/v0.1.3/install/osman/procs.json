{
  "lang": "Rust",
  "homepage": "https://github.com/dalance/procs",
  "desc": {
    "cn": "用 Rust 编写的 ps 的现代替代",
    "en": "A modern replacement for ps written in Rust"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use procs",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install procs",
      "reference": "https://github.com/dalance/procs"
    },
    "debian/snap": {
      "cmd": "sudo snap install procs",
      "reference": "https://github.com/dalance/procs"
    },
    "ubuntu/snap": {
      "cmd": "sudo snap install procs",
      "reference": "https://github.com/dalance/procs"
    },
    "alpine/apk": {
      "cmd": "sudo apk add procs",
      "reference": "https://github.com/dalance/procs",
      "dsnap": "procs"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S procs",
      "reference": "https://github.com/dalance/procs"
    },
    "arch/yay": {
      "cmd": "yay -S procs-git",
      "reference": "https://aur.archlinux.org/packages/procs-git"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install procs",
      "reference": "https://github.com/dalance/procs",
      "dsnap": "procs"
    },
    "opensuse/snap": {
      "cmd": "sudo snap install procs",
      "reference": "https://github.com/dalance/procs"
    },
    "nix/nixpkgs": {
      "cmd": "nix-env --install procs",
      "reference": "https://github.com/dalance/procs"
    },
    "darwin/port": {
      "cmd": "sudo port selfupdate && sudo port install procs",
      "reference": "https://github.com/dalance/procs"
    },
    "(win|wsl2)/winget": {
      "cmd": "x winget install procs",
      "reference": "https://github.com/dalance/procs"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop install procs",
      "reference": "https://github.com/dalance/procs"
    },
    "(win|wsl2)/choco": {
      "cmd": "x choco install bat",
      "reference": "https://github.com/dalance/procs"
    }
  }
}
