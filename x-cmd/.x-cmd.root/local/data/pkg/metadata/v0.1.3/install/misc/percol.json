{
  "lang": "Python",
  "homepage": "https://github.com/mooz/percol",
  "desc": {
    "cn": "在 UNIX 上的传统管道概念中添加交互式选择的风格",
    "en": "adds flavor of interactive filtering to the traditional pipe concept of UNIX shell"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use percol",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "sudo pip install percol",
      "reference": "https://github.com/mooz/percol?tab=readme-ov-file#installation",
      "dsnap": "percol"
    },
    "arch/yay": {
      "cmd": "yay -S percol-git",
      "reference": "https://aur.archlinux.org/packages/percol-git"
    }
  }
}
