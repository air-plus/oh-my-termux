{
  "homepage": "https://github.com/xo/usql",
  "desc": {
    "cn": "用于与 SQL 数据库交互的通用命令行界面",
    "en": "Universal command-line interface for SQL databases"
  },
  "lang": "go",
  "rule": {
    "/x": {
      "cmd": "x pkg use usql",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use usql",
      "reference": "https://github.com/itspngu/asdf-usql"
    },
    "darwin/brew": {
      "cmd": "brew install xo/xo/usql",
      "reference": "https://github.com/xo/usql?tab=readme-ov-file#installing-via-homebrew-macos-and-linux"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S usql",
      "reference": "https://github.com/xo/usql?tab=readme-ov-file#installing-via-aur-arch-linux"
    },
    "arch/yay": {
      "cmd": "yay -S usql",
      "reference": "https://aur.archlinux.org/packages/usql"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop install usql",
      "reference": "https://github.com/xo/usql#installing"
    }
  }
}
