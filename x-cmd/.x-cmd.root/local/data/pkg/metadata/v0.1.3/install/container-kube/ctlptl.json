{
  "lang": "Go",
  "homepage": "https://github.com/tilt-dev/ctlptl",
  "desc": {
    "cn": "ctlptl 是一个用于声明性地设置本地 Kubernetes 集群的 CLI",
    "en": "ctlptl is a CLI for declaratively setting up local Kubernetes clusters"
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S ctlptl-bin",
      "reference": "https://aur.archlinux.org/packages/ctlptl-bin"
    },
    "/asdf": {
      "cmd": "x asdf use ctlptl",
      "reference": "https://github.com/ezcater/asdf-ctlptl?tab=readme-ov-file#install"
    }
  }
}
