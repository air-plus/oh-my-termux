{
  "lang": "Java",
  "homepage": "https://github.com/iterate-ch/cyberduck",
  "desc": {
    "cn": "一款适用于 macOS 和 Windows 的自由文件传输客户端",
    "en": "A libre file transfer client for macOS and Windows."
  },
  "rule": {
    "darwin/brew": {
      "cmd": "brew install duck",
      "reference": "https://docs.duck.sh/cli/"
    },
    "darwin/port": {
      "cmd": "sudo port install duck",
      "reference": "https://docs.duck.sh/cli/"
    },
    "(win|wsl2)/choco": {
      "cmd": "choco install duck",
      "reference": "https://docs.duck.sh/cli/"
    },
    "arch/yay": {
      "cmd": "yay -S duck",
      "reference": "https://aur.archlinux.org/packages/duck"
    }
  }
}
