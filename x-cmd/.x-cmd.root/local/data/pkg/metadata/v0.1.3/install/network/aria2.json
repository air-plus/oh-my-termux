{
  "lang": "c++",
  "homepage": "https://aria2.github.io/",
  "desc": {
    "cn": "一款功能强大的命令行下载工具。它支持同时下载多个文件，并能够从多个来源获取数据，以提供更快的下载速度",
    "en": "An efficient compression algorithm and tool designed to provide fast compression and decompression speeds while maintaining a high compression ratio"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use aria2",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use aria2",
      "reference": "https://github.com/asdf-community/asdf-aria2"
    },
    "darwin/brew": {
      "cmd": "brew install aria2",
      "reference": "https://formulae.brew.sh/formula/aria2#default"
    },
    "debian/apt": {
      "cmd": "sudo apt-get install aria2",
      "reference": "https://command-not-found.com/aria2c",
      "dsnap": "aria2"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install aria2",
      "reference": "https://command-not-found.com/aria2c",
      "dsnap": "aria2"
    },
    "alpine/apk": {
      "cmd": "sudo apk add aria2",
      "reference": "https://command-not-found.com/aria2c",
      "dsnap": "aria2"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S aria2",
      "reference": "https://command-not-found.com/aria2c"
    },
    "arch/yay": {
      "cmd": "yay -S aria2-git",
      "reference": "https://aur.archlinux.org/packages/aria2-git"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install aria2",
      "reference": "https://command-not-found.com/aria2c",
      "dsnap": "aria2"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install aria2",
      "reference": "https://command-not-found.com/aria2c",
      "dsnap": "aria2"
    },
    "raspbian/apt": {
      "cmd": "sudo apt-get install aria2",
      "reference": "https://command-not-found.com/aria2c"
    }
  }
}
