{
  "lang": "c#",
  "homepage": "https://dotnet.microsoft.com/en-us/",
  "desc": {
    "cn": ".NET 是免费的、开源的、跨平台的框架，用于构建新式应用和强大的云服务",
    "en": ".NET is the free, open-source, cross-platform framework for building modern apps and powerful cloud services"
  },
  "rule": {
    "arch/yay": {
      "cmd": "yay -S dotnet-sdk-bin",
      "reference": "https://aur.archlinux.org/packages/dotnet-sdk-bin"
    },
    "/homebrew": {
      "cmd": "brew install --cask dotnet-sdk@9",
      "reference": "https://formulae.brew.sh/cask/dotnet-sdk@9"
    }
  }
}
