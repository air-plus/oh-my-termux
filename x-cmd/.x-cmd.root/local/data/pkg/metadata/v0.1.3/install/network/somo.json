{
  "lang": "Rust",
  "homepage": "https://github.com/theopfr/somo",
  "desc": {
    "cn": "一种用于 Linux 和 macOS 上套接字和端口监控的人性化 netstat 替代方案",
    "en": "A human-friendly alternative to netstat for socket and port monitoring on Linux and macOS."
  },
  "rule": {
    "/cargo": {
      "cmd": "cargo install somo",
      "reference": "https://github.com/theopfr/somo?tab=readme-ov-file#%EF%B8%8F-installation",
      "dsnap": "somo"
    },
    "arch/yay": {
      "cmd": "yay -S somo",
      "reference": "https://aur.archlinux.org/packages/somo"
    }
  }
}
