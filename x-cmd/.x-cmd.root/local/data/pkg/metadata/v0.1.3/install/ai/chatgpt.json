{
  "lang": "Go",
  "homepage": "https://github.com/j178/chatgpt",
  "desc": {
    "cn": "适用于 ChatGPT 的命令行界面",
    "en": "Command line interface for ChatGPT"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use chatgpt",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install j178/tap/chatgpt",
      "reference": "https://github.com/j178/chatgpt#installation"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop bucket add j178 https://github.com/j178/scoop-bucket.git \\\n&& x scoop install j178/chatgpt\n",
      "reference": "https://github.com/j178/chatgpt#installation"
    },
    "darwin/nix": {
      "cmd": "environment.systemPackages = [pkgs.chatgpt-cli];",
      "reference": "https://github.com/j178/chatgpt#installation"
    },
    "arch/yay": {
      "cmd": "yay -S chatgpt-bin",
      "reference": "https://aur.archlinux.org/packages/chatgpt-bin"
    }
  }
}
