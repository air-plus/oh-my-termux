{
  "lang": "c",
  "homepage": "https://developers.google.com/speed/webp/docs/precompiled",
  "desc": {
    "cn": "WebP 编码器工具",
    "en": "WebP encoder tool"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use cwebp",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install webp",
      "reference": "https://formulae.brew.sh/formula/webp"
    }
  },
  "binlist": [
    "cwebp"
  ]
}
