{
  "lang": "c#",
  "homepage": "https://github.com/nilaoda/BBDown",
  "desc": {
    "cn": "一款命令行式哔哩哔哩下载器",
    "en": "A command-line Bilibili Downloader"
  },
  "rule": {
    "/dotnet": {
      "cmd": "dotnet tool install --global BBDown",
      "reference": "https://github.com/nilaoda/BBDown"
    },
    "arch/yay": {
      "cmd": "yay -S bbdown-bin",
      "reference": "https://aur.archlinux.org/packages/bbdown-bin"
    }
  }
}
