{
  "lang": "Go",
  "homepage": "https://docs.syncthing.net/intro/getting-started.html",
  "desc": {
    "cn": "Syncthing 是一个连续文件同步程序",
    "en": "Syncthing is a continuous file synchronization program"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use syncthing",
      "reference": "https://x-cmd.com/install/"
    },
    "/curl": {
      "cmd": "curl -sS https://webinstall.dev/syncthing | bash",
      "reference": "https://docs.syncthing.net/users/contrib.html#id1"
    },
    "debian/apt": {
      "cmd": "sudo apt-get install syncthing",
      "reference": "https://apt.syncthing.net/",
      "dsnap": "syncthing"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install syncthing",
      "reference": "https://apt.syncthing.net/",
      "dsnap": "syncthing"
    },
    "alpine/apk": {
      "cmd": "apk add syncthing",
      "reference": "https://command-not-found.com/syncthing"
    },
    "kali/apt": {
      "cmd": "sudo apt-get install syncthing",
      "reference": "https://command-not-found.com/syncthing",
      "dsnap": "syncthing"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S syncthing",
      "reference": "https://command-not-found.com/syncthing"
    },
    "fedora/dnf": {
      "cmd": "sudo dnf install syncthing",
      "reference": "https://command-not-found.com/syncthing"
    },
    "raspbian/apt": {
      "cmd": "sudo apt-get install syncthing",
      "reference": "https://command-not-found.com/syncthing"
    },
    "arch/yay": {
      "cmd": "yay -S syncthing-bin",
      "reference": "https://aur.archlinux.org/packages/syncthing-bin"
    }
  }
}
