{
  "lang": "Go",
  "homepage": "https://github.com/zu1k/nali",
  "desc": {
    "cn": "一个查询 IP 地理信息和 CDN 服务提供商的离线终端工具",
    "en": "An offline tool for querying IP geographic information and CDN provider"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use nali",
      "reference": "https://x-cmd.com/install/"
    },
    "/go": {
      "cmd": "go install github.com/zu1k/nali@latest",
      "reference": "https://github.com/zu1k/nali/blob/master/README_en.md#install-from-source",
      "dsnap": "github.com/zu1k/nali@latest"
    },
    "arch/yay": {
      "cmd": "yay -S nali-go-bin",
      "reference": "https://aur.archlinux.org/packages/nali-go-bin"
    }
  }
}
