{
  "lang": "Python",
  "homepage": "https://docs.locust.io/",
  "desc": {
    "cn": "Locust 是一个用于 HTTP 和其他协议的开源性能/负载测试工具",
    "en": "Locust is an open source performance/load testing tool for HTTP and other protocols"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use locust",
      "reference": "https://x-cmd.com/install/"
    },
    "/pip": {
      "cmd": "pip install locust",
      "reference": "https://docs.locust.io/en/stable/installation.html#installation"
    },
    "darwin/brew": {
      "cmd": "brew install locust",
      "reference": "https://formulae.brew.sh/formula/locust#default"
    },
    "arch/yay": {
      "cmd": "yay -S python-locust",
      "reference": "https://aur.archlinux.org/packages/python-locust"
    }
  }
}
