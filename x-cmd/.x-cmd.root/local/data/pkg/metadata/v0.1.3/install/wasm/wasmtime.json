{
  "homepage": "https://wasmtime.dev/",
  "desc": {
    "cn": "一个快速、安全的 WebAssembly 运行时",
    "en": "A fast and secure runtime for WebAssembly"
  },
  "lang": "rust",
  "rule": {
    "/x": {
      "cmd": "x pkg use wasmtime",
      "reference": "https://x-cmd.com/install/"
    },
    "/asdf": {
      "cmd": "x asdf use wasmtime",
      "reference": "https://github.com/tachyonicbytes/asdf-wasmtime"
    },
    "/curl": {
      "cmd": "curl https://wasmtime.dev/install.sh -sSf | bash",
      "reference": "https://wasmer.io/"
    },
    "darwin/brew": {
      "cmd": "brew install wasmtime",
      "reference": "https://formulae.brew.sh/formula/wasmtime#default"
    },
    "arch/yay": {
      "cmd": "yay -S wasmtime-git",
      "reference": "https://aur.archlinux.org/packages/wasmtime-git"
    }
  }
}
