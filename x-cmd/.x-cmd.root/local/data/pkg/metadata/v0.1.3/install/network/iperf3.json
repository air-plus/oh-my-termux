{
  "lang": "C",
  "homepage": "https://github.com/esnet/iperf",
  "desc": {
    "cn": "iperf3 是一款网络带宽测量工具，支持 TCP、UDP、SCTP 协议，可测试最大带宽、吞吐量、抖动和丢包率。",
    "en": "iperf3 is a tool for active measurements of the maximum achievable bandwidth on IP networks, supporting TCP, UDP, and SCTP."
  },
  "rule": {
    "darwin/brew": {
      "cmd": "brew install iperf3",
      "reference": "https://formulae.brew.sh/formula/iperf3#default"
    },
    "debian/apt-get": {
      "cmd": "apt-get install iperf3",
      "reference": "https://command-not-found.com/iperf3",
      "dsnap": "iperf3"
    },
    "ubuntu/apt-get": {
      "cmd": "apt-get install iperf3",
      "reference": "https://command-not-found.com/iperf3",
      "dsnap": "iperf3"
    },
    "alpine/apk": {
      "cmd": "apk add iperf3",
      "reference": "https://command-not-found.com/iperf3"
    },
    "arch/pacman": {
      "cmd": "pacman -S iperf3",
      "reference": "https://command-not-found.com/iperf3"
    },
    "kali/apt-get": {
      "cmd": "apt-get install iperf3",
      "reference": "https://command-not-found.com/iperf3"
    },
    "fedora/dnf": {
      "cmd": "dnf install iperf3",
      "reference": "https://command-not-found.com/iperf3"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop bucket add main\nx scoop install main/iperf3\n",
      "reference": "https://scoop.sh/#/apps?q=iperf3"
    },
    "(win|wsl2)/choco": {
      "cmd": "x choco install iperf3",
      "reference": "https://community.chocolatey.org/packages/iperf3"
    }
  },
  "binlist": [
    "iperf3"
  ]
}
