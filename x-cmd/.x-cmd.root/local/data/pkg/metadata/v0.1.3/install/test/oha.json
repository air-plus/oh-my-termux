{
  "homepage": "https://github.com/hatoo/oha",
  "lang": "Rust",
  "desc": {
    "cn": "HTTP 负载生成器",
    "en": "HTTP load generator"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use oha",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install oha",
      "reference": "https://formulae.brew.sh/formula/oha#default"
    },
    "/cargo": {
      "cmd": "cargo install oha",
      "reference": "https://crates.io/crates/oha",
      "dsnap": "oha"
    },
    "arch/pacman": {
      "cmd": "sudo pacman -S oha",
      "reference": "https://github.com/hatoo/oha?tab=readme-ov-file#on-macos-homebrew"
    },
    "arch/yay": {
      "cmd": "yay -S oha-git",
      "reference": "https://aur.archlinux.org/packages/oha-git"
    }
  }
}
