{
  "lang": "c",
  "desc": {
    "cn": "基于命令行的 Markdown 演示工具",
    "en": "Command line-based Markdown presentation tool"
  },
  "homepage": "https://github.com/visit1985/mdp",
  "rule": {
    "debian/apt": {
      "cmd": "sudo apt-get install mdp",
      "reference": "https://github.com/visit1985/mdp",
      "dsnap": "mdp"
    },
    "ubuntu/apt": {
      "cmd": "sudo apt-get install mdp",
      "reference": "https://github.com/visit1985/mdp",
      "dsnap": "mdp"
    },
    "arch/yay": {
      "cmd": "yay -S mdp-git",
      "reference": "https://aur.archlinux.org/packages/mdp-git"
    }
  }
}
