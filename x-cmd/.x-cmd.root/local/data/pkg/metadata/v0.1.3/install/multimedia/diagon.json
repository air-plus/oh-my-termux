{
  "lang": "c++",
  "homepage": "https://github.com/ArthurSonzogni/Diagon",
  "desc": {
    "cn": "交互式 ASCII 艺术图表生成器",
    "en": "Interactive ASCII art diagram generators"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use diagon",
      "reference": "https://x-cmd.com/install/"
    },
    "(linux|darwin|win|wsl2)/": {
      "cmd": "x env use diagon",
      "reference": "https://x-cmd.com/mod/env"
    },
    "/snap": {
      "cmd": "sudo snap install diagon",
      "reference": "https://github.com/ArthurSonzogni/Diagon?tab=readme-ov-file#command-line-interface"
    },
    "/nix": {
      "cmd": "nix run github:petertrotman/nixpkgs/Diagon#diagon",
      "reference": "https://github.com/ArthurSonzogni/Diagon?tab=readme-ov-file#command-line-interface"
    },
    "arch/yay": {
      "cmd": "yay -S diagon-bin",
      "reference": "https://aur.archlinux.org/packages/diagon-bin"
    }
  }
}
