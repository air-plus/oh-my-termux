{
  "lang": "rust",
  "desc": {
    "cn": "用于查看系统信息",
    "en": "View system information"
  },
  "homepage": "https://github.com/macchina-cli/macchina",
  "rule": {
    "/x": {
      "cmd": "x pkg use macchina",
      "reference": "https://x-cmd.com/install/"
    },
    "/cargo": {
      "cmd": "cargo add macchina",
      "reference": "https://crates.io/crates/macchina",
      "dsnap": "macchina"
    },
    "darwin/brew": {
      "cmd": "brew install macchina",
      "reference": "https://github.com/Macchina-CLI/macchina/wiki/Installation#homebrew"
    },
    "opensuse/zypper": {
      "cmd": "sudo zypper in macchina",
      "reference": "https://github.com/Macchina-CLI/macchina/wiki/Installation#opensuse-tumbleweed"
    },
    "arch/yay": {
      "cmd": "yay -S macchina-git",
      "reference": "https://aur.archlinux.org/packages/macchina-git"
    }
  }
}
