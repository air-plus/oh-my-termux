{
  "lang": "Python",
  "homepage": "https://github.com/9001/copyparty",
  "desc": {
    "cn": "便携式文件服务器，具有加速可恢复上传、重复数据删除、WebDAV、FTP、TFTP、零配置、媒体索引器、缩略图++ 等功能，全部包含在一个文件中，无依赖项",
    "en": "Portable file server with accelerated resumable uploads, dedup, WebDAV, FTP, TFTP, zeroconf, media indexer, thumbnails++ all in one file, no deps"
  },
  "rule": {
    "/pip": {
      "cmd": "pip install --user -U copyparty",
      "reference": "https://github.com/9001/copyparty?tab=readme-ov-file#quickstart",
      "dsnap": "copyparty"
    },
    "/uv": {
      "cmd": "uv tool run copyparty",
      "reference": "https://github.com/9001/copyparty?tab=readme-ov-file#quickstart",
      "dsnap": "copyparty"
    },
    "arch/pacman": {
      "cmd": "pacman -S copyparty",
      "reference": "https://github.com/9001/copyparty?tab=readme-ov-file#arch-package"
    },
    "nix/nix": {
      "cmd": "nix profile install github:9001/copyparty",
      "reference": "https://github.com/9001/copyparty?tab=readme-ov-file#nix-package"
    },
    "darwin/brew": {
      "cmd": "brew install copyparty",
      "reference": "https://formulae.brew.sh/formula/copyparty#default"
    }
  }
}
