{
  "lang": "Go",
  "homepage": "https://github.com/golang-migrate/migrate",
  "desc": {
    "cn": "用 Go 编写的数据库迁移工具，用作 CLI 或导入为库",
    "en": "Database migrations written in Go,use as CLI or import as library"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use migrate",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install golang-migrate",
      "reference": "https://formulae.brew.sh/formula/golang-migrate#default"
    },
    "/scoop": {
      "cmd": "scoop install main/migrate",
      "reference": "https://scoop.sh/#/apps?q=migrate"
    },
    "arch/yay": {
      "cmd": "yay -S migrate",
      "reference": "https://aur.archlinux.org/packages/migrate"
    }
  }
}
