{
  "lang": "Typescript",
  "homepage": "https://github.com/github/copilot-cli",
  "desc": {
    "cn": "GitHub Copilot CLI 将 Copilot 编码代理的功能直接带到您的终端",
    "en": "GitHub Copilot CLI brings the power of Copilot coding agent directly to your terminal."
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use copilot",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install -g @github/copilot",
      "reference": "https://github.com/github/copilot-cli?tab=readme-ov-file#installation",
      "dsnap": "@github/copilot"
    },
    "(win|wsl2)/winget": {
      "cmd": "winget install GitHub.Copilot",
      "reference": "https://github.com/github/copilot-cli?tab=readme-ov-file#installation"
    },
    "darwin/brew": {
      "cmd": "brew install copilot-cli",
      "reference": "https://github.com/github/copilot-cli?tab=readme-ov-file#installation"
    },
    "/curl": {
      "cmd": "curl -fsSL https://gh.io/copilot-install | bash",
      "reference": "https://github.com/github/copilot-cli?tab=readme-ov-file#installation"
    },
    "/wget": {
      "cmd": "wget -qO- https://gh.io/copilot-install | bash",
      "reference": "https://github.com/github/copilot-cli?tab=readme-ov-file#installation"
    }
  },
  "binlist": [
    "copilot"
  ]
}
