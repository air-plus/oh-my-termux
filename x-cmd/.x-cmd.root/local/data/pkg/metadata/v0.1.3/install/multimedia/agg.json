{
  "lang": "rust",
  "homepage": "https://github.com/asciinema/agg",
  "desc": {
    "cn": "asciinema gif 生成器",
    "en": "asciinema gif generator"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use agg",
      "reference": "https://x-cmd.com/install/"
    },
    "darwin/brew": {
      "cmd": "brew install agg",
      "reference": "https://formulae.brew.sh/formula/agg#default"
    },
    "/cargo": {
      "cmd": "cargo install --git https://github.com/asciinema/agg",
      "reference": "https://github.com/asciinema/agg?tab=readme-ov-file#building",
      "dsnap": "agg"
    },
    "(win|wsl2)/scoop": {
      "cmd": "x scoop install agg",
      "reference": "https://scoop.sh/#/apps?q=agg"
    },
    "arch/yay": {
      "cmd": "yay -S asciinema-agg",
      "reference": "https://aur.archlinux.org/packages/asciinema-agg"
    }
  }
}
