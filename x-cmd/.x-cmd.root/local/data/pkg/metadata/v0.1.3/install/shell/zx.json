{
  "lang": "node",
  "homepage": "https://github.com/google/zx",
  "desc": {
    "cn": "能让你用 js 编写各种类型脚本的工具",
    "en": "Tools that allow you to write various types of scripts using js"
  },
  "rule": {
    "/x": {
      "cmd": "x pkg use zx",
      "reference": "https://x-cmd.com/install/"
    },
    "/npm": {
      "cmd": "npm install -g zx",
      "reference": "https://google.github.io/zx/getting-started#install",
      "dsnap": "zx"
    },
    "arch/yay": {
      "cmd": "yay -S zx",
      "reference": "https://aur.archlinux.org/packages/zx"
    }
  }
}
