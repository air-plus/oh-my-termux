{	"homepage"	:	"https://asciinema.org"	,	"license"	:	"GNU GPLv3"	,	"source"	:	{	"official"	:	[	"https://pypi.org/project/asciinema/"	]	,	"repack-official"	:	[	"https://pypi.tuna.tsinghua.edu.cn/simple/asciinema/"	]	}	,	"hook"	:	{	"populate"	:	"populate.sh"	}	,	"path"	:	{	"bin"	:	"shim_bin"	}	,	"_build"	:	"0"	,	"tree"	:	"%{os}.%{arch}.%{_build}"	,	"rule"	:	{	"/*"	:	{	"version"	:	"stable"	}	,	"stable/*"	:	{	"version"	:	"v2.4.0"	}	,	"latest/*"	:	{	"version"	:	"v2.4.0"	}	,	"*/linux/arm64"	:	{	"_build"	:	"glib"	}	,	"*/darwin/arm64"	:	null	,	"*/linux/x64"	:	{	"_build"	:	"musl"	}	,	"*/darwin/x64"	:	null	,	"*/win/x64"	:	null	,	"v2.4.0/*/*"	:	{	"dep"	:	[	"miniconda=v3.10.0+23.9.0-0"	]	}	,	"v3.0.1/*/*"	:	{	"gh_url"	:	"https://github.com/x-cmd-build/asciinema/releases/download/%{semantic_version}"	,	"download_file_ext"	:	"tar.xz"	,	"zipname"	:	"%{tree}.%{download_file_ext}"	,	"unpack"	:	"folder"	,	"url"	:	{	"internet"	:	"%{gh_url}/%{zipname}"	,	"cn"	:	"%{gh_url}/%{zipname}"	}	,	"npm"	:	"yes"	,	"npmurl"	:	{	"internet"	:	"https://registry.npmjs.org/@x-cmd-pkg/asciinema/-/asciinema-0.0.0-%{version}-%{os}.%{arch}.%{_build}.tgz"	,	"cn"	:	"https://registry.npmmirror.com/@x-cmd-pkg/asciinema/-/asciinema-0.0.0-%{version}-%{os}.%{arch}.%{_build}.tgz"	}	}	}	}	