{
"-A|--askpass"
:
{
"#desc"
:
{
"cn"
:
"使用外部 helper 程序进行密码提示"
,
"en"
:
"Use a helper program for password prompting"
}
}
,
"-b|--background"
:
{
"#desc"
:
{
"cn"
:
"在后台运行命令"
,
"en"
:
"Run command in the background"
}
}
,
"-B|--bell"
:
{
"#desc"
:
{
"cn"
:
"在提示输入密码时响铃"
,
"en"
:
"Ring bell when prompting"
}
}
,
"-C|--close-from"
:
{
"#desc"
:
{
"cn"
:
"关闭编号大于等于指定值的所有文件描述符"
,
"en"
:
"Close all file descriptors greater than or equal to num"
}
,
"#1"
:
{
"#desc"
:
{
"en"
:
"num"
,
"cn"
:
"编号"
}
}
}
,
"-D|--chdir"
:
{
"#desc"
:
{
"cn"
:
"在执行命令前切换工作目录"
,
"en"
:
"Change the working directory before running command"
}
,
"#1"
:
{
"#desc"
:
{
"en"
:
"directory"
,
"cn"
:
"目录"
}
,
"#exec"
:
"___x_cmd_advise__dir"
}
}
,
"-E|--preserve-env"
:
{
"#desc"
:
{
"cn"
:
"运行命令时保留当前用户环境变量"
,
"en"
:
"Preserve user environment when running command"
}
}
,
"--preserve-env"
:
{
"#desc"
:
{
"cn"
:
"仅保留指定的环境变量"
,
"en"
:
"Preserve specific environment variables"
}
,
"#1"
:
{
"#desc"
:
{
"en"
:
"environment variables"
,
"cn"
:
"环境变量"
}
}
}
,
"-e|--edit"
:
{
"#desc"
:
{
"cn"
:
"编辑文件而不是执行命令"
,
"en"
:
"Edit files instead of running a command"
}
}
,
"-g|--group"
:
{
"#desc"
:
{
"cn"
:
"以指定的用户组身份运行命令"
,
"en"
:
"Run command as the specified group name or ID"
}
,
"#1"
:
{
"#desc"
:
{
"en"
:
"group name or ID"
,
"cn"
:
"用户组名或ID"
}
}
}
,
"-H|--set-home"
:
{
"#desc"
:
{
"cn"
:
"将 HOME 设置为目标用户的主目录"
,
"en"
:
"Set HOME variable to target user's home directory"
}
}
,
"-h|--help"
:
{
"#desc"
:
{
"cn"
:
"显示帮助信息并退出"
,
"en"
:
"Display help message and exit"
}
}
,
"-h|--host"
:
{
"#desc"
:
{
"cn"
:
"在指定主机上运行命令（需插件支持）"
,
"en"
:
"Run command on host (if supported by plugin)"
}
,
"#1"
:
{
"#desc"
:
{
"en"
:
"host"
,
"cn"
:
"主机"
}
}
}
,
"-i|--login"
:
{
"#desc"
:
{
"cn"
:
"以目标用户身份运行登录 shell"
,
"en"
:
