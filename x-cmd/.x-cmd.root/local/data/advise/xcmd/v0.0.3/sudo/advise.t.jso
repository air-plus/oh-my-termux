}
}
,
"-K|--remove-timestamp"
:
{
"#desc"
:
{
"cn"
:
"完全移除 sudo 时间戳文件"
,
"en"
:
"Remove timestamp file completely"
}
}
,
"-k|--reset-timestamp"
:
{
"#desc"
:
{
"cn"
:
"使 sudo 时间戳失效"
,
"en"
:
"Invalidate timestamp file"
}
}
,
"-l|--list"
:
{
"#desc"
:
{
"cn"
:
"列出用户权限或检查指定命令的权限"
,
"en"
:
"List user's privileges or check a specific command"
}
}
,
"-n|--non-interactive"
:
{
"#desc"
:
{
"cn"
:
"非交互模式，不进行任何提示"
,
"en"
:
"Non-interactive mode, no prompts are used"
}
}
,
"-P|--preserve-groups"
:
{
"#desc"
:
{
"cn"
:
"保留当前用户的组列表"
,
"en"
:
