}
}
,
"-v|--validate"
:
{
"#desc"
:
{
"cn"
:
"刷新 sudo 时间戳而不执行命令"
,
"en"
:
"Update user's timestamp without running a command"
}
}
,
"--"
:
{
"#desc"
:
{
"cn"
:
"停止处理后续命令行参数"
