:
"Browser window width"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"窗口宽度（整数）"
,
"en"
:
"window width (integer)"
}
}
}
,
"--window-height"
:
{
"#desc"
:
{
"cn"
:
"设置浏览器窗口高度"
,
"en"
:
"Browser window height"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"窗口高度（整数）"
,
"en"
:
"window height (integer)"
}
}
}
,
"--user-data-dir"
:
{
"#desc"
:
{
"cn"
:
"指定 Chrome 本地用户数据目录"
,
