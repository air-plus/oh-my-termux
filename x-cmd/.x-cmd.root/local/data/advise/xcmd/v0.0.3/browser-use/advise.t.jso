}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"连接到现有 Chrome 实例的 CDP 地址（如 http://localhost:9222）"
,
"en"
:
"Connect to existing Chrome via CDP URL (e.g. http://localhost:9222)"
}
}
}
,
"--prompt|-p"
:
{
"#desc"
:
{
"cn"
:
"使用 prompt 参数直接运行命令"
,
"en"
:
"Run a single task via prompt"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"在无头模式下直接运行指定任务"
,
"en"
:
"Run a single task without the TUI (headless mode)"
}
}
}
,
"--mcp"
:
{
"#desc"
:
{
"cn"
:
"以 MCP 模式运行（通过 stdin/stdout 暴露 JSON RPC）"
,
"en"
:
